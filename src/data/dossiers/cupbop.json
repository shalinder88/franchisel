      "distinctive_or_unusual_clauses": [
        {
          "clause": "Non-compete radius 20 miles from ANY Cupbop",
          "why_distinctive": "Most concepts use franchisee's own premises radius. This clause makes post-term reentry into UT/AZ/ID effectively impossible."
        },
        {
          "clause": "Cross-default: any default under any other agreement with franchisor or affiliates triggers noncurable default",
          "why_distinctive": "Combined with the parent-supplier relationship (Cupbop Co. supplies sauces/proteins), a payment dispute with the supplier could become an FA termination event."
        },
        {
          "clause": "Sales performance kill switch (50% of trailing-12-month national average over 2 years)",
          "why_distinctive": "Most concepts use absolute revenue targets or quartile thresholds; the moving national-average benchmark means a franchisee can default by underperforming relative to a system-wide rising tide even if their absolute sales are stable."
        },
        {
          "clause": "Renewal FA 'may be materially different'",
          "why_distinctive": "Open-ended future-burden risk. New royalty rates, new fees, new territory restrictions could all be imposed at renewal."
        },
        {
          "clause": "Franchisor option to purchase at FMV upon termination/expiration",
          "why_distinctive": "Combined with right of first refusal on transfers, franchisor controls exit liquidity in both directions."
        },
        {
          "clause": "Confidentiality clauses on franchisees that 'may restrict ability to speak openly'",
          "why_distinctive": "Disclosed in Item 20; reduces value of franchisee references in due diligence."
        }
