        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due": "With written request", "remarks": "See Note 2"},
        {"type": "OnQ Computer System Fees", "amount": "$29,568 to $116,556", "due": "As agreed", "remarks": "See Note 3"},
        {"type": "Other Initial Start-Up Fees", "amount": "$5,100", "due": "On or before opening", "remarks": "GRO, Digital Floor Plan, HOTT"},
        {"type": "Restaurant Brands Initial Fee", "amount": "$47,500", "due": "When signed", "remarks": "Optional, per brand"},
        {"type": "Training Program Fees", "amount": "$5,000 to $20,000", "due": "As agreed", "remarks": "See Item 11"},
        {"type": "Opening Process Services Fee", "amount": "$6,000", "due": "Before opening", "remarks": "Pre-opening services"},
        {"type": "Procurement and Services Fees", "amount": "4% to 10% of project cost", "due": "As agreed", "remarks": "See Note 5"}
      ],
      "table_notes": [
        "Note 1: Refundable minus $7,500 processing fee if denied/withdrawn. In 2024, fees ranged $0-$100K new dev, $0-$200K COO, $50K-$100K re-licensing.",
