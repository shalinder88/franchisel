      "rows": [
        {"fee_type": "Initial Franchise Fee", "amount": "$10,000", "refundable": "$5,000 working capital deposit refundable at termination"},
        {"fee_type": "Additional Franchise Fee", "amount": "$5,000 per additional restaurant", "refundable": "Non-refundable"},
        {"fee_type": "Pre-Opening Insurance", "amount": "$4,100–$200,000/yr", "refundable": "Non-refundable"},
        {"fee_type": "Pre-Opening Inventory (CFA Supply)", "amount": "$15,000–$65,000", "refundable": "Non-refundable"}
      ],
      "table_notes": [
        "Initial franchise fee: $5,000 fully earned on payment; $5,000 maintained as working capital deposit.",
        "Working capital deposit refunded within 2.5 months after termination/non-renewal, less costs and losses.",
        "Pre-opening expenditures not due until after restaurant opens."
      ]
    },
    {
      "table_id": "item6_fee_table",
      "source_item": "Item 6",
      "source_pages": [27, 28, 29, 30, 31, 32],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Advertising", "amount": "0%–3.25% of GR", "due_date": "Monthly", "remarks": "Currently 0% since June 30, 1989"},
        {"type": "Advertising Support & Services", "amount": "$100/hr blended rate + costs", "due_date": "As incurred", "remarks": "Optional in-house agency alternative"},
        {"type": "Additional Franchise Fee", "amount": "$5,000 per additional business", "due_date": "At signing", "remarks": "For additional restaurants"},
        {"type": "Business Services Fee", "amount": "$300", "due_date": "Monthly", "remarks": "Mandatory"},
        {"type": "Rent (Traditional)", "amount": "$2,725–$96,285/mo", "due_date": "Monthly", "remarks": "Includes percentage rent; capped at 6% of annual GR by internal policy"},
        {"type": "Occupancy Charge (Captive Venue)", "amount": "4%–30% of GR", "due_date": "Monthly or per agreement", "remarks": "Passed through dollar-for-dollar"},
        {"type": "Use/Occupancy Charge (Delivery Kitchen)", "amount": "4%–30% of GR", "due_date": "Monthly or per DK Lease", "remarks": "Passed through dollar-for-dollar"},
        {"type": "Food Truck Usage Fee (Subleased)", "amount": "$2,100–$3,738/mo + costs", "due_date": "Monthly", "remarks": "In lieu of CFA lease rental to lessor"},
        {"type": "Food Truck Fee (Vendor-leased)", "amount": "$7,000–$7,500", "due_date": "At signing or monthly", "remarks": "License fee to CFA"},
        {"type": "Food Truck Insurance Fee", "amount": "$305–$525/mo", "due_date": "Monthly", "remarks": "Covers truck and contents"},
        {"type": "Insurance", "amount": "$260–$10,240/mo", "due_date": "Monthly", "remarks": "See Item 8"},
        {"type": "Equipment Rental", "amount": "$750–$5,000/mo", "due_date": "Monthly", "remarks": "Free-standing/in-line $5,000; drive-thru $4,000; mall $3,000; captive $750–$3,000; delivery kitchen $2,500–$5,000"},
        {"type": "Hardware/Software Support + Internet", "amount": "$9,500–$20,000/yr", "due_date": "As incurred", "remarks": "May be reduced for captive venue/delivery kitchen"},
        {"type": "Operating Service Fees", "amount": "Formula-based", "due_date": "Monthly", "remarks": "Base = 15% of GR minus equipment rental and business services fee; Additional = 50% of Net Profit"},
        {"type": "Fines (Minimum Standards)", "amount": "Varies", "due_date": "As incurred", "remarks": "For failure to maintain standards"},
        {"type": "Indemnification", "amount": "Varies", "due_date": "As incurred", "remarks": "Claims from restaurant operations"},
        {"type": "Credit Card/Gift Card Fees", "amount": "Varies", "due_date": "As incurred", "remarks": "System-negotiated rates; CFA Servco for gift cards"},
        {"type": "Highway Signage", "amount": "Varies", "due_date": "As incurred", "remarks": "Fabrication + annual expense"},
        {"type": "Interest on Late Payments", "amount": "Max legal rate or 1.25%/mo", "due_date": "As incurred", "remarks": "Compounded monthly"},
        {"type": "Cash Handling System", "amount": "$85–$450/mo", "due_date": "As incurred", "remarks": "May not apply to mall/office/captive/delivery kitchen"},
        {"type": "Reimbursement of Cost of Performance", "amount": "Costs + interest", "due_date": "As incurred", "remarks": "If CFA performs Operator obligations"},
        {"type": "Holdover Liquidated Damages", "amount": "Double base + percentage rent", "due_date": "As incurred", "remarks": "For occupancy after lease termination"}
      ],
      "table_notes": [
        "Note 1: All fees imposed by CFA; non-refundable; imposed uniformly except as noted.",
        "Note 2: Operating Service Fee formula calculates Base Operating Service Fee (15% GR – equipment rental – business services fee) and Additional Operating Service Fee (50% of Net Profit).",
        "Note 3: Fees calculated monthly, paid from GR on monthly or pro rata daily basis.",
        "Note 5: CFA acts as agent for collecting and accounting for GR.",
        "Note 6: Rent Policy (since Jan 1, 2015) caps rent at 6% of annual GR — non-contractual, revocable.",
        "Note 8: Cash handling fees may not apply if vendor services not available in area or location is mall/office/captive venue/delivery kitchen."
      ]
    },
