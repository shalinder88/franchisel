      "rows": [
        {"fee": "Franchise Application Fee - New Development or Conversion", "amount": "$100,000 plus $400 per additional guest room/suite over 250", "due": "With Application", "notes": "Note 1; refundable less $7,500 processing fee pre-approval"},
        {"fee": "Franchise Application Fee - Change of Ownership", "amount": "$200,000", "due": "With Application", "notes": "Note 1; 2024 actuals $7,500-$200,000"},
        {"fee": "Franchise Application Fee - Re-licensing", "amount": "$100,000", "due": "With Application", "notes": "Note 1"},
        {"fee": "Property Improvement Plan (PIP) Fee", "amount": "$10,000", "due": "Before PIP inspection", "notes": "Conversion/COO/Re-licensing"},
        {"fee": "Construction/Renovation Work Extension Fee", "amount": "$10,000", "due": "With written request for extension", "notes": "30-day rolling automatic extensions initially free"},
        {"fee": "OnQ Computer System - Hardware/Software/Install", "amount": "$70,576-$151,184", "due": "As agreed", "notes": "Proprietary; from HSS"},
