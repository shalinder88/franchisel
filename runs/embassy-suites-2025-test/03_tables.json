        {"fee": "Eforea Spa Initial Fee", "amount": "$25,000", "due": "When signing Spa Amendment", "notes": "Optional; only if installing Eforea spa"},
        {"fee": "Training Program Fees", "amount": "$5,000-$17,500", "due": "As agreed", "notes": "Plus traveler expenses"},
        {"fee": "Opening Process Services Fee", "amount": "$6,000", "due": "Before opening", "notes": ""},
        {"fee": "Procurement & Services Fees (HSM)", "amount": "4%-10% of project cost", "due": "As agreed", "notes": "Optional; plus cost of products and freight"}
