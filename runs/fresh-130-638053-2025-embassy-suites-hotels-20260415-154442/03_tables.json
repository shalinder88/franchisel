        {"type": "Monthly Royalty Fee - New Dev/Conv", "amount": "3.5% Y1 / 4.5% Y2 / 5.5% remainder of GRR", "due": "Monthly by 15th", "remarks": "See Note 1"},
        {"type": "Monthly Royalty Fee - COO/Re-licensing", "amount": "5.5% of GRR", "due": "Monthly by 15th", "remarks": "See Note 1"},
        {"type": "Monthly Spa Royalty Fee", "amount": "2% of Gross Spa Revenue", "due": "Monthly by 15th", "remarks": "If eforea spa"},
        {"type": "Monthly Program Fee", "amount": "4% of GRR", "due": "Monthly by 15th", "remarks": "Can increase up to +1% over term. See Note 2"},
        {"type": "Room Addition Fee", "amount": "$400/suite", "due": "With Application", "remarks": "Non-refundable once approved"},
        {"type": "OnQ Connectivity", "amount": "$400-$600/month", "due": "Monthly", "remarks": "Based on workstation count"},
        {"type": "Hardware/Software Maintenance", "amount": "$1,735-$4,128/month", "due": "Monthly by 15th", "remarks": "OnQ maintenance by HSS"},
        {"type": "OnQ Email", "amount": "$7.92/user/month + $12.50/month mobile", "due": "Quarterly", "remarks": "Min 3 accounts"},
        {"type": "Connected Room Maintenance", "amount": "$721-$1,062/month", "due": "Monthly by 15th", "remarks": ""},
        {"type": "Delphi System", "amount": "$858/user/year", "due": "Annually", "remarks": "License and maintenance via HSS"},
        {"type": "Guest Assistance - Satisfaction Guarantee", "amount": "$200-$300/transaction", "due": "Within 48 hours", "remarks": "Diamond $300, Gold $250, Others $200"},
        {"type": "Guest Assistance - Price Match", "amount": "25% discount off lower rate", "due": "When stay consumed", "remarks": ""},
        {"type": "Brand Non-Compliance Fee", "amount": "$65-$145/approved room", "due": "Within 10 days", "remarks": "Capped $50K per 6-month period"},
        {"type": "Brand Non-Compliance Re-Evaluation", "amount": "Up to $4,500", "due": "Within 10 days", "remarks": ""},
        {"type": "Brand Non-Compliance Special Audit", "amount": "$5,500", "due": "Within 10 days", "remarks": ""},
        {"type": "PIP/Renovation Failure Fee", "amount": "$10,000 every 6 months", "due": "Within 10 days", "remarks": ""},
        {"type": "Stay Score Failure Fee", "amount": "Up to $300/room or 0.5% GRR annually", "due": "Within 10 days", "remarks": "Assessed at least twice/year"},
        {"type": "Service Quality Improvement Program", "amount": "$20,000-$50,000 per 6-month period", "due": "Within 10 days", "remarks": "If below min service quality 6+ months"},
        {"type": "Brand Conference", "amount": "$2,500/attendee", "due": "Before attendance", "remarks": "GM and Director of Sales required"},
        {"type": "Hilton Honors", "amount": "4.3% of total eligible guest folio", "due": "10 days after billing", "remarks": "Waived for on-property enrollment stays"},
        {"type": "Hilton Advance Program", "amount": "1.35% of eligible Digital Direct Revenue (max $30/stay)", "due": "Within 15 days or 12th business day", "remarks": ""},
        {"type": "Hilton For Business", "amount": "Up to 3% of GRR per eligible stay", "due": "As incurred", "remarks": "Optional; auto-enrolled, may opt out"},
        {"type": "Third-Party Reservation Charges", "amount": "Up to $5.93/stay", "due": "By 20th of month", "remarks": "GDS, airline, internet reservation providers"},
        {"type": "FastPay Program", "amount": "Up to $1.40/transaction + commission", "due": "Within 15 days or 12th business day", "remarks": "Up to 7% commissions"},
        {"type": "COO Application Fee", "amount": "$200,000", "due": "With Application", "remarks": ""},
        {"type": "Permitted Transfer Processing Fee", "amount": "$5,500", "due": "When submitting request", "remarks": ""},
        {"type": "Re-licensing Application Fee", "amount": "$100,000", "due": "With Application", "remarks": ""},
        {"type": "Lender Comfort Letter", "amount": "$3,500 (letter) / $1,500 (assignment)", "due": "Before issuance", "remarks": ""},
        {"type": "Liquidated Damages - Pre-Opening", "amount": "System's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages - Post-Opening (first 2 yrs)", "amount": "Greater of Hotel's or System's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages - Post-Opening (after 2 yrs)", "amount": "Hotel's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages - Last 60 months", "amount": "Hotel's Avg Monthly Royalty x remaining months", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Service Charges for Overdue Payments", "amount": "1.5%/month", "due": "On demand", "remarks": "Or highest rate permissible by law"}
      ],
      "table_notes": [
        "Note 1: GRR = Gross Rooms Revenue including Mandatory Guest Fees, reward point redemptions, breakfast if bundled. Royalty modified in 6 instances in 2024.",
        "Note 2: Program Fee will not exceed current rate + 1% GRR over term. Covers reservations, directories, advertising, QA, technology, admin.",
        "Note 8: Hotel's Avg Monthly Royalty = 24-month lookback / 24 (or proportional if <24 months). System's Avg = per-room average × hotel rooms. Excludes financial accommodations and business interruption periods."
      ]
    },
