        {"type": "Supplier/Supplies Approval", "amount": "Reasonable cost of inspection", "due_date": "Time of inspection", "remarks": "For unapproved suppliers"},
        {"type": "General Contractor Approval", "amount": "$5,000 each", "due_date": "At construction start", "remarks": "May be waived"},
        {"type": "Architect Approval", "amount": "$5,000 each", "due_date": "At construction start", "remarks": "May be waived"},
        {"type": "Operation in Absence/Death", "amount": "$125/hour plus expenses", "due_date": "Weekly", "remarks": "Rate subject to change"},
