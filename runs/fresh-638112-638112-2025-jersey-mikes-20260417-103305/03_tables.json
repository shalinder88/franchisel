        {"type": "Relocation Fee", "amount": "$5,000 plus costs", "due_date": "At relocation", "remarks": "If Company allows relocation"},
        {"type": "Bookkeeping/Accounting Fee", "amount": "~$150/week (subject to change)", "due_date": "Within 10 days after month end", "remarks": "Coach Rod Smith participants only"},
        {"type": "Indemnification", "amount": "All costs + attorneys fees", "due_date": "On settlement/conclusion", "remarks": "Franchisee holds Company harmless"},
        {"type": "Liquidated Damages", "amount": "Avg monthly royalty+ad × lesser of 36 or remaining months", "due_date": "Upon termination for default", "remarks": "In addition to other damages"}
