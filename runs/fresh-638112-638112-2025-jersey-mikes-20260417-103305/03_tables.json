        {"type": "Secure Network Fee", "amount": "$31.85/month (may increase to $39.85/month)", "due_date": "1st of month", "remarks": "Credit card processing and data transfer"},
        {"type": "Back-Up Cellular Service", "amount": "$30/month", "due_date": "1st of month", "remarks": "Subject to change"},
        {"type": "Teamworx Software Fee", "amount": "$53.50/month (optional; $59.99 by April 2026)", "due_date": "1st of month", "remarks": "Labor management via Crunchtime platform"},
        {"type": "Gift Card Program", "amount": "$9.50/month", "due_date": "1st of month", "remarks": "Collected by Company, paid to vendor"},
        {"type": "Third-Party Delivery Fee", "amount": "$6-$9 per delivery", "due_date": "As incurred", "remarks": "Based on delivery distance"},
        {"type": "Online Ordering Fees", "amount": "$0.2921/transaction + 3.74% of sale", "due_date": "1st of month", "remarks": "Credit card, patent licensing, e-commerce, sales tax, authentication"},
        {"type": "Third-Party Order Fees", "amount": "$0.2921/transaction (not currently charged)", "due_date": "1st of month", "remarks": "Third-party order integration"},
        {"type": "Text Message Fees", "amount": "$0.025/text", "due_date": "As incurred", "remarks": "Franchisee-initiated texts only"},
        {"type": "Transfer Fee", "amount": "$15,000 per restaurant", "due_date": "At closing", "remarks": "Does not apply to Section 19.6 assignments"},
        {"type": "Replacement Training", "amount": "Up to $2,500 per trainee", "due_date": "In advance", "remarks": "Subject to change"},
        {"type": "Additional Assistance", "amount": "$75/hour plus expenses", "due_date": "Time of assistance", "remarks": "3 days included at opening"},
        {"type": "Continuing Education", "amount": "Your expenses + employee expenses", "due_date": "Time of program", "remarks": "Max 2x/year, 4 days total"},
        {"type": "Maintenance", "amount": "Cost of maintenance", "due_date": "Time of maintenance", "remarks": "If franchisee fails, Company may enter premises"},
