    {
      "table_id": "T02",
      "title": "Other Fees (Item 6)",
      "source_item": "Item 6",
      "source_pages": [10, 11, 12],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Type of Fee": "Royalty Fee", "Amount": "Greater of (a) 7% of weekly Gross Sales or (b) $350 per week", "Due Date": "Weekly by EFT, each Wednesday", "Remarks": "Begins at earlier of studio opening or opening deadline"},
        {"Type of Fee": "Brand Fund Fee", "Amount": "Currently $420 per month", "Due Date": "Same time as Royalty Fee", "Remarks": "May increase up to 10% per year (compounding allowed)"},
        {"Type of Fee": "Local Advertising", "Amount": "$1,200 per month minimum", "Due Date": "Monthly", "Remarks": "Up to $2,300/mo; must use LeadTeam; additional $1,000 first 6 months and if sales decline >5% in 3-month period"},
        {"Type of Fee": "Marketing Management Fee", "Amount": "Currently $1,200", "Due Date": "Monthly", "Remarks": "To LeadTeam; may increase 10%/yr"},
        {"Type of Fee": "Successor Fee", "Amount": "Currently $10,000", "Due Date": "30 days before FA expires", "Remarks": "Not to exceed 50% of then-current IFF"},
        {"Type of Fee": "Testing and Evaluation Fee", "Amount": "Reasonable cost of inspection", "Due Date": "When requested", "Remarks": "Wages, travel, expenses for supplier/product approval"},
        {"Type of Fee": "Initial Training Fee - Transfer", "Amount": "Currently $5,000 per person", "Due Date": "When incurred", "Remarks": "Not to exceed $7,500/person"},
        {"Type of Fee": "Remedial Training Fee", "Amount": "Currently $500 per day plus costs", "Due Date": "When incurred", "Remarks": "Up to 5 days/yr; not to exceed $1,000/person"},
        {"Type of Fee": "Costs and Attorneys' Fees", "Amount": "Variable", "Due Date": "When incurred", "Remarks": "If franchisee loses dispute"},
        {"Type of Fee": "Collections Fees", "Amount": "Variable", "Due Date": "When incurred", "Remarks": "Costs of collecting amounts owed"},
        {"Type of Fee": "Designated Software License Fee", "Amount": "Currently $695 per month", "Due Date": "Monthly", "Remarks": "Subject to change on written notice"},
        {"Type of Fee": "Interest Expenses", "Amount": "Greater of 1.5% per month or max legal rate", "Due Date": "When due", "Remarks": "On late royalty, brand fund, or other amounts"},
        {"Type of Fee": "Convention", "Amount": "Currently $1,000 per participant plus costs", "Due Date": "When incurred", "Remarks": "Not to exceed $1,500/person"},
        {"Type of Fee": "Transfer Fee (Single Unit)", "Amount": "25% of then-current IFF plus costs", "Due Date": "Before transfer", "Remarks": "Exceptions for controlled entities, 3-yr franchisees, family, death/disability"},
        {"Type of Fee": "Transfer Fee (Multi-Unit)", "Amount": "$5,000 per unmet development obligation plus costs", "Due Date": "Before transfer", "Remarks": "Transferee must complete training"},
        {"Type of Fee": "Relocation Fee", "Amount": "$5,000 or greater", "Due Date": "When incurred", "Remarks": "Plus build-out costs at new location"},
        {"Type of Fee": "Securities Offering Fee", "Amount": "Greater of $10,000 or actual costs", "Due Date": "When incurred", "Remarks": "Requires written consent to financing method"},
        {"Type of Fee": "Securities Update Fee", "Amount": "Actual costs", "Due Date": "When incurred", "Remarks": "For ongoing securities reporting"},
        {"Type of Fee": "Insurance", "Amount": "Cost of insurance", "Due Date": "Before opening", "Remarks": "5% admin fee if franchisor procures"},
        {"Type of Fee": "Audit", "Amount": "Variable", "Due Date": "When incurred", "Remarks": "Understatement >2% = fees+interest+audit costs; >5% = termination"},
        {"Type of Fee": "Management Fee", "Amount": "Greater of $2,000/wk or 20% of Gross Sales plus costs", "Due Date": "When incurred", "Remarks": "Only if Studio Manager not replaced within 30 days"},
        {"Type of Fee": "Liquidated Damages", "Amount": "Complex formula based on trailing 12-month fees x (lesser of 36 or remaining months)", "Due Date": "On termination", "Remarks": "Not a penalty per FDD"},
        {"Type of Fee": "Remodeling Expenses", "Amount": "Variable", "Due Date": "Within 90 days of notice", "Remarks": "Range from painting to full refurbishment"},
        {"Type of Fee": "Income and Sales Taxes", "Amount": "Cost of taxes from IP licensing", "Due Date": "Monthly by EFT", "Remarks": "Only if state collects"},
        {"Type of Fee": "Extension Fee (Multi-Unit)", "Amount": "$5,000 per studio", "Due Date": "As incurred", "Remarks": "One 3-month extension per studio"}
      ],
      "table_notes": [
        "Note 1: All fees non-refundable and uniformly imposed unless noted.",
        "Note 2: Gross Sales defined excluding taxes, refunds, insurance proceeds, and uncollectibles (capped at 0.5% of GS).",
        "Note 3: Local advertising must use LeadTeam; additional $1,000 first 6 months and during sales decline periods.",
        "Note 4: Marketing Management Fee to LeadTeam may increase up to 10% per year.",
        "Note 5: Software from designated provider; portion attributable to costs tracks costs, overhead portion capped at 25%.",
        "Note 6: Convention attendance may be mandatory; all travel costs are franchisee's responsibility.",
        "Note 7: Transfer fee exceptions for controlled entities, 3-year franchisees, family members, death/disability.",
        "Note 8: MUD transfer requires compliance, approval, training, fee, and general release.",
        "Note 9: Securities offering requires written consent, $10,000 fee, and specific disclosures.",
        "Note 10: Audit understatement 2% or less = pay fees+interest; 2-5% = +audit costs; 5%+ = termination.",
        "Note 11: Remodeling within 90 days of notice; scope varies from painting to full refurbishment."
      ],
      "provenance": "Item 6, pages 10-13 of FDD"
    },
