      "item": "Item 5",
      "title": "Initial Fees Schedule",
      "source_pages": [21],
      "columns": ["Scenario", "Fee", "Notes"],
      "rows": [
        {"scenario": "New construction", "fee": "Up to $10,000", "notes": "Initial franchise application processing fee"},
        {"scenario": "Refranchising closed store", "fee": "Up to $10,000", "notes": "Initial franchise application processing fee"},
        {"scenario": "Purchasing existing store", "fee": "$1,500", "notes": "Transfer fee"},
        {"scenario": "Training fee", "fee": "Up to $1,250/session", "notes": "Operational and classroom training"},
        {"scenario": "Reservation fee (Development Agreement)", "fee": "$25,000", "notes": "If fail to meet DA requirements; non-refundable"}
      ],
      "table_notes": ["Initial Fee payable before issuance, non-refundable. Generally not billed until operating.", "Payments to DPF/affiliates + Initial Fee: $117,950-$196,500 (Traditional), $69,950-$187,500 (Non-Traditional)."]
    },
    {
      "id": "item6_fee_table",
      "item": "Item 6",
      "title": "Other Fees",
      "source_pages": [22, 23, 24, 25, 26, 27],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Royalty Fee", "amount": "5.5% of weekly Royalty Sales", "due": "EFT by Thursday weekly", "remarks": "Royalty Sales = total receipts less taxes, approved coupons"},
        {"fee": "Advertising Fund", "amount": "4% of weekly Royalty Sales", "due": "Same as Royalty", "remarks": "Non-Traditional may receive partial credit"},
        {"fee": "Advertising Cooperatives", "amount": "1-4%", "due": "Same as Royalty", "remarks": "May be required; see Item 11"},
        {"fee": "PULSE initial license fee", "amount": "$4,200", "due": "As invoiced", "remarks": "Paid to DPL"},
        {"fee": "Third Party Vendor PULSE Fees", "amount": "$1,357.04", "due": "As invoiced", "remarks": "Annual, subject to adjustment"},
        {"fee": "Annual Software Enhancement Fee", "amount": "$819.25/yr (after year 1)", "due": "As invoiced", "remarks": "Max 5% annual increase unless OAC approves"},
        {"fee": "Help Desk/Software Support", "amount": "$44/call, $28/chat", "due": "As invoiced", "remarks": ""},
        {"fee": "Connectivity Fee", "amount": "$1,200/yr", "due": "As invoiced", "remarks": "If no broadband where available"},
        {"fee": "Flex Client Fee", "amount": "$150/device", "due": "As invoiced", "remarks": "Chrome OS devices"},
        {"fee": "Annual Service Fee (SmartRecruiters)", "amount": "$432/yr per store", "due": "As invoiced", "remarks": "Application processing"},
        {"fee": "Technology Transaction Fee", "amount": "$0.385/digital order", "due": "As invoiced", "remarks": "Per Online Ordering Agreement"},
        {"fee": "Credit Card Processing Fee", "amount": "$0.0525/transaction", "due": "As invoiced", "remarks": "Security costs"},
        {"fee": "Spanish Language Call Center", "amount": "$3.00/call", "due": "As invoiced", "remarks": "Monthly per store"},
        {"fee": "Inspections", "amount": "Varies", "due": "As incurred", "remarks": "Travel, room/board, compensation"},
        {"fee": "Audit Expenses", "amount": "Cost + 1.5%/mo interest", "due": "10 days after final audit", "remarks": "If >2% understatement"},
        {"fee": "Transfer", "amount": "$1,500", "due": "Before transfer", "remarks": "Per transfer of FA, assets, or ownership"},
        {"fee": "Training Fees", "amount": "Max $1,250/session", "due": "Upon registration", "remarks": "Supplemental max $500"},
        {"fee": "Interest on Late Payments", "amount": "Lesser of 1.5%/mo or highest legal rate", "due": "As incurred", "remarks": "2% above Libor for AK/HI"},
        {"fee": "Testing/Evaluation", "amount": "Varies", "due": "As incurred", "remarks": "See Item 8"},
        {"fee": "Indemnification", "amount": "Varies", "due": "As incurred", "remarks": "Hold harmless obligation"},
        {"fee": "Costs of Enforcement/Non-compliance", "amount": "Varies", "due": "As incurred", "remarks": "Customer Care: $20 first/$30 subsequent"},
        {"fee": "Carryout Tracker Bundle", "amount": "$440.87", "due": "As invoiced", "remarks": "Flex Client + cabling"},
        {"fee": "Server Bundle", "amount": "$4,025.20", "due": "As invoiced", "remarks": "Pair of servers"},
        {"fee": "Meraki Licensing", "amount": "$280.00/yr", "due": "As invoiced", "remarks": "WAP & router licensing"},
        {"fee": "Meraki Router/WAP Bundle", "amount": "$1,039.34", "due": "As invoiced", "remarks": "Hardware only"},
        {"fee": "Lane 3600 Wired Customer Facing", "amount": "$709.92", "due": "As invoiced", "remarks": "CC reader + 3yr warranty"},
        {"fee": "Lane 3000 Wired EPP", "amount": "$496.34", "due": "As invoiced", "remarks": "Handheld payment terminal"},
        {"fee": "Flex Client", "amount": "$431.07", "due": "As invoiced", "remarks": ""},
        {"fee": "Menuboard Client Bundle", "amount": "$483.31", "due": "As invoiced", "remarks": "Flex client + cabling"},
        {"fee": "Environmental/EPR Costs", "amount": "Varies", "due": "As invoiced", "remarks": "OR and CO currently; packaging compliance"}
      ],
      "table_notes": [
        "(1) All fees imposed by and payable to us or affiliates. Non-refundable.",
        "(2) Incentive programs may reduce royalty and/or advertising for periods.",
        "(3) Royalty Sales exclude taxes, approved coupons; Non-Traditional stadium/airport commissions deducted.",
        "(4) Current advertising rate is 4%. Certain pre-April 2025 Non-Traditional agreements may have different rate.",
        "(5) Non-Traditional Stores may get up to 3.5% of 4% rebated for local advertising.",
        "(6) If 65%+ of cooperative stores agree, same rate applies; min 2%; max 9% combined.",
        "(7) PULSE hardware $15,000-$25,000; annual maintenance ~$7,000; enhancement fee max 5% increase/yr; Brand Technology additions capped at 1.5% of cumulative Royalty Sales."
      ]
    },
