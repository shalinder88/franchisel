      "title": "Initial Franchise Fee Schedule",
      "columns": ["Restaurant Type", "Initial Franchise Fee"],
      "rows": [
        {"restaurant_type": "Standard Traditional Restaurant", "initial_franchise_fee": "$35,000"},
        {"restaurant_type": "Standard Traditional Restaurant Previously Operated and Closed within the Last Year", "initial_franchise_fee": "$12,500, or $5,000 for existing franchisee in good standing"},
        {"restaurant_type": "Non-Traditional Location", "initial_franchise_fee": "$17,500 (or $1,750 × number of full or partial years in the term, up to 10 years)"}
