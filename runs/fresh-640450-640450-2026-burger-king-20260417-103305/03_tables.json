{
  "tables": [
    {
      "id": "item5_franchise_fee",
      "item": "5",
      "title": "Franchise Fee Structure",
      "source_pages": [29, 30, 31, 32, 33],
      "columns": ["Program", "Fee", "Conditions"],
      "rows": [
        {"program": "Standard", "fee": "$50,000", "conditions": "20-year term; prorated for shorter terms, min $15,000"},
        {"program": "TRA Deposit", "fee": "$5,000", "conditions": "Per restaurant opening committed"},
        {"program": "MTRA Deposit", "fee": "$10,000 x # restaurants", "conditions": "Per restaurant opening committed"},
        {"program": "Development Agreement", "fee": "$50,000 prepaid per restaurant", "conditions": "Credited against franchise fees; FSS grade-based after exhaustion"},
        {"program": "Dev Agreement (A/B grade)", "fee": "$25,000", "conditions": "After prepaid fees exhausted"},
        {"program": "Dev Agreement (D/F grade)", "fee": "Base Fee (greater of $50,000 or then-current)", "conditions": "After prepaid fees exhausted"},
        {"program": "RTF2 Successor", "fee": "$2,500/year x additional years", "conditions": "Total years = 20 from remodel deadline"},
        {"program": "Training", "fee": "$7,500 per trainee", "conditions": "Non-refundable, payable before training begins"},
        {"program": "CYC Deposit", "fee": "$7,500", "conditions": "Within 5 days of Term Sheet signing"}
      ],
      "table_notes": [
        "Franchise fee is fully earned upon signing and non-refundable",
        "Application fee: $250/individual, $5,000/entity — non-refundable"
      ],
      "provenance": "Item 5, pages 29-33"
    },
    {
      "id": "item6_fee_table",
      "item": "6",
      "title": "Other Fees",
      "source_pages": [34, 35, 36, 37, 38, 39, 40],
      "columns": ["Fee Type", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee_type": "Royalty", "amount": "4.5% of monthly Gross Sales", "due_date": "Monthly, 10th of next month", "remarks": "See Note 2 for reduction programs"},
        {"fee_type": "Advertising", "amount": "Up to 4.5% of monthly Gross Sales", "due_date": "Same as royalty", "remarks": "See Note 3 for reduction programs"},
        {"fee_type": "Rent (BKL/BKG)", "amount": "Varies — see Note 4", "due_date": "Monthly, 1st of month (base); as agreed (percentage)", "remarks": "Net of all taxes, CAM, insurance"},
        {"fee_type": "Service Desk Fee", "amount": "$750-$1,200/year per restaurant", "due_date": "On demand", "remarks": "Centralized IT support"},
        {"fee_type": "Late Charges", "amount": "$0-$75/month", "due_date": "On demand", "remarks": "$0 if <$2K; $30 if $2K-$5K; $75 if >$5K"},
        {"fee_type": "CYC Late Charges", "amount": "2% above Promissory Note rate", "due_date": "On demand", "remarks": "Overdue CYC loan amounts"},
        {"fee_type": "Stamp Tax", "amount": "$0.35/$100", "due_date": "On demand", "remarks": "Florida instruments only"},
        {"fee_type": "Transfer Fee", "amount": "$2,000 first + $500 each additional", "due_date": "At sale/transfer", "remarks": "$175 weekend/holiday surcharge; $2,000 Intercreditor Agreement"},
        {"fee_type": "Application Fee", "amount": "$250/individual; up to $5,000/entity", "due_date": "At application", "remarks": ""},
        {"fee_type": "Training Fee", "amount": "$7,500 per trainee", "due_date": "Before training or at transfer", "remarks": ""},
        {"fee_type": "Entity/LLC Fee", "amount": "Up to $5,000/entity + up to $1,000/restaurant", "due_date": "At conversion", "remarks": "$1K/restaurant (1-10); $0 (11-20); $500 (21+)"},
        {"fee_type": "Franchise Extension Fee", "amount": "$2,500 annually", "due_date": "At signing", "remarks": "BKC not obligated to extend"},
        {"fee_type": "Investment Spending", "amount": "Up to 2.0% of Gross Sales", "due_date": "Monthly, 10th", "remarks": "DMA-determined; Majority Clause may require participation"},
        {"fee_type": "Sales Transfer Study", "amount": "$3,000-$8,000/restaurant", "due_date": "As arranged", "remarks": "BKC decides who pays"},
        {"fee_type": "Sales Impact Contribution", "amount": "Varies", "due_date": "As agreed", "remarks": "Development dispute resolution costs"},
        {"fee_type": "Gift Card Services", "amount": "Setup $40; Transaction ~1.8% of redeemed sales", "due_date": "To vendor/supplier", "remarks": "Mandatory BK Crown Card participation"},
        {"fee_type": "BK University/Support", "amount": "$600/year per restaurant", "due_date": "On demand", "remarks": "eLearning platform and training materials"},
        {"fee_type": "Digital Services Fee", "amount": "$110/mo + 1% digital sales; cap $4,500/yr", "due_date": "Monthly, 10th", "remarks": "BK app, website, third-party ordering, ROYAL PERKS"},
        {"fee_type": "Static Menu Board Kit", "amount": "$200-$300/month", "due_date": "Monthly", "remarks": "Only if no outdoor digital menu board"},
        {"fee_type": "Misc Reimbursements/Training", "amount": "Up to $25,000/person", "due_date": "As agreed", "remarks": "Course, material, travel expenses"},
        {"fee_type": "Follow-Up Walk-Thru", "amount": "$1,500", "due_date": "On demand", "remarks": "If remodel not substantially complete"},
        {"fee_type": "One-Time Cure Fee", "amount": "TRA: $10,000; MTRA: balance x #", "due_date": "At development failure", "remarks": "Must also open by extended date"},
        {"fee_type": "Deferred Remodel Default", "amount": "Royalty increases to 6.0% or 7.5%", "due_date": "Monthly until remodel complete", "remarks": "Prior incentive program defaults"},
        {"fee_type": "Audit Expenses", "amount": "Cost of audit", "due_date": "Within 15 days of audit report", "remarks": "If Gross Sales understated >2%"},
        {"fee_type": "Indemnity", "amount": "Losses and expenses incurred", "due_date": "On demand", "remarks": "Includes third-party claims from Services Agreement"},
        {"fee_type": "Costs & Attorneys' Fees", "amount": "Varies", "due_date": "After notice", "remarks": "If BKC successful in legal action; $2,500 arbitration deposit"},
        {"fee_type": "Background Check", "amount": "$145-$15,000", "due_date": "On demand", "remarks": "$225 US, $145 Canada, $1K-$15K international"},
        {"fee_type": "BK Foundation", "amount": "$1,000/year per restaurant", "due_date": "On demand", "remarks": "Purchase or fundraise in-restaurant"},
        {"fee_type": "DA Brand Damage Fee", "amount": "Remaining prepaid franchise fees", "due_date": "Upon demand", "remarks": "If DA terminated before expiration"},
        {"fee_type": "DA Indirect Tax", "amount": "Applicable taxes on DA fees", "due_date": "Upon demand", "remarks": "Sales, VAT, excise, etc."},
        {"fee_type": "DA Base Fees", "amount": "See Notes 2 and 3", "due_date": "Upon demand", "remarks": "Royalty and advertising base fees"},
        {"fee_type": "Product Testing/Approval", "amount": "Up to $30,000/product or supplier", "due_date": "On demand", "remarks": "New product/supplier evaluation costs"},
        {"fee_type": "Third-Party Food Safety Inspections", "amount": "Cost of re-inspection", "due_date": "On demand", "remarks": "Only if failed initial inspection"},
        {"fee_type": "Resale Fee (Carrols)", "amount": "$10,000/restaurant", "due_date": "30 days after closing", "remarks": ""},
        {"fee_type": "Sublease Fee (Carrols)", "amount": "Varies", "due_date": "30 days after closing", "remarks": "Reimburse landlord consent costs"}
      ],
      "table_notes": [
        "Note 1: Fees may vary by negotiation; prior FA holders may pay different rates",
        "Note 2: Royalty reduction programs: 2024 DIP (2.5-4.5% ramp), RTF2, DA (FSS-based), CYC additional 1-5%",
        "Note 3: Advertising reduction programs: 2024 DIP (2.0-Base Fee ramp), DA (FSS-based), Fuel the Flame 4.5% through 2027+",
        "Note 4: BKL rent typically 10% capitalized costs + 8.5%/10% percentage rent; escalation 12%/5 years if BKC-owned",
        "Note 5: Late charge schedule: $0 ($1-$2K), $30 ($2K-$5K), $75 ($5K+)",
        "Note 6: Entity/LLC conversion fees: $5K/entity + $1K/restaurant (1-10), $0 (11-20), $500 (21+)",
        "Note 7: Sales Impact Contribution per development dispute resolution procedures",
        "Note 8: Digital Services Fee covers BK app, website, third-party ordering platforms, ROYAL PERKS loyalty"
      ],
      "provenance": "Item 6, pages 34-48"
    },
