        {"type": "Liquidated Damages - Pre-Opening Termination", "amount": "System's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages - Post-Opening (before 2nd anniv.)", "amount": "Greater of Hotel's or System's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages - Post-Opening (after 2nd anniv.)", "amount": "Hotel's Avg Monthly Royalty x 60", "due": "On demand", "remarks": "Before final 60 months. See Note 8"},
        {"type": "Liquidated Damages - Last 60 months", "amount": "Hotel's Avg Monthly Royalty x remaining months", "due": "On demand", "remarks": "See Note 8"},
        {"type": "Service Charges for Overdue Payments", "amount": "1.5%/month or max by law", "due": "On demand", "remarks": ""},
        {"type": "Identity/Sales/Distribution Non-Compliance", "amount": "$500/instance", "due": "On demand", "remarks": "Cost-recovery fee"},
        {"type": "FastPay Non-Compliance", "amount": "$500 to $3,000/violation", "due": "On demand", "remarks": "Escalating"},
        {"type": "Restaurant Brands Annual Fee", "amount": "$14,500/brand", "due": "Annually by Jan 15", "remarks": "Per brand"},
        {"type": "Consortia Program", "amount": "Up to $3.00/consumed room night + 10% commission", "due": "Monthly", "remarks": "Requires participation in 3 programs simultaneously"},
        {"type": "TMC Pay-On-All", "amount": "Up to $1.85/consumed room night + 10% commission", "due": "Monthly", "remarks": "See Note 5"},
        {"type": "TMC SMB Program", "amount": "Up to $1.85/consumed room night + 10% commission", "due": "Monthly", "remarks": "See Note 5"},
        {"type": "US Government Travel", "amount": "Up to $2.30/night or 1.45% consumed room revenue; FedRooms/DOD: 2.25%", "due": "Monthly", "remarks": "Optional"},
        {"type": "ResMax Program", "amount": "5.4% to 5.9% of consumed revenue (3-night max)", "due": "As required", "remarks": "Optional, supplemental"},
        {"type": "RMCC (Monthly)", "amount": "$835 to $15,709/month (varies by category)", "due": "Within 10 days", "remarks": "Optional except certain circumstances. See Note 9"},
        {"type": "Procurement Services", "amount": "4% to 10% of project cost", "due": "As agreed", "remarks": "HSM"}
      ],
      "table_notes": [
        "Note 1: GRR includes mandatory guest fees, no-show revenue, cancellation fees. 24 instances of modified royalty in 2024.",
        "Note 2: Program Fee rate may increase up to +1% GRR over term. Funds reservations, directories, advertising, QA, technology.",
        "Note 3: QA program includes Plans & Designs Late Fee, Brand Non-Compliance Fees, PIP/Renovation Failure Fee, Stay Score Failure Fee, Service Quality Improvement Program fees.",
        "Note 5: Sales/distribution programs may be added, removed, modified. May be mandatory. Auto-enrollment possible.",
        "Note 6: Hilton Honors 4.3% on eligible stays. Additional bonus points = additional fees. Hotels must allocate rooms for free night redemptions.",
        "Note 8: Hotel's Average Monthly Royalty: total royalty for 24 months ÷ 24 (or pro-rata if <24 months). System's Average: system-wide avg royalty/room × hotel rooms. Excludes temporary accommodations and business interruptions.",
        "Note 9: RMCC required if expedited opening ≤150 days and hotel GRR >$6M (Intermediate) or >$10M (Premier)."
      ]
