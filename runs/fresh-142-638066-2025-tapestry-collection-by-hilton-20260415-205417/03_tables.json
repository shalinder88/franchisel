      "source_pages": [23, 24, 25],
      "title": "Initial Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Franchise Application Fee - New Dev/Conversion", "amount": "$100,000 plus $400/room over 250", "due": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee - Change of Ownership", "amount": "$150,000", "due": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee - Re-licensing", "amount": "$100,000", "due": "With Application", "remarks": "See Note 1"},
        {"type": "PIP Fee", "amount": "$10,000", "due": "Before PIP inspection", "remarks": "Conversion/COO/Re-licensing"},
        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due": "With written request", "remarks": "See Note 2"},
        {"type": "OnQ Computer System", "amount": "$103,500 to $273,500", "due": "As agreed", "remarks": "See Note 3"},
        {"type": "Other Initial Start Up Fees", "amount": "$6,500", "due": "As incurred before opening", "remarks": "GRO, Digital Floor Plan, Hilton Opening Transition Tool"},
        {"type": "Eforea Spa Initial Fee", "amount": "$47,500", "due": "When you sign Spa Amendment", "remarks": "See Note 4"},
        {"type": "Restaurant Brand Initial Fee", "amount": "$47,500", "due": "When you sign Restaurant Brands Amendment", "remarks": "Per brand. See Note 5"},
        {"type": "Training Program Fees", "amount": "$5,000 to $15,000", "due": "As agreed", "remarks": "GM and key personnel"},
        {"type": "Opening Process Services Fee", "amount": "$20,000", "due": "Before opening", "remarks": "Pre-opening services"},
        {"type": "RMCC Pre-Opening Support", "amount": "$4,059 to $8,880", "due": "Within 10 days of billing", "remarks": "Expedited opening 150 days or less"},
        {"type": "Procurement and Services Fees", "amount": "4% to 10% of project cost", "due": "As agreed", "remarks": "If using HSM. See Note 6"},
        {"type": "Miscellaneous Services", "amount": "As agreed", "due": "As agreed", "remarks": "Optional and mandatory services"}
      ],
      "table_notes": [
        "Note 1: $7,500 processing fee retained if withdrawn/denied. In 2024, actual fees ranged $25K-$100K for New Dev/Conversion/COO, $0-$10K for Re-licensing.",
        "Note 2: New Development must start within 16 months; automatic 30-day rolling extensions until 60-day notice. Not for Re-licensing/COO/room additions.",
        "Note 3: Includes hardware, software, installation for OnQ system. Refresh required every 3 years.",
        "Note 4: Eforea spa is optional. Fee is nonrefundable.",
        "Note 5: Restaurant Brands are optional. Fee per brand selected.",
        "Note 6: HSM procurement fee of 4%-10% plus product cost, freight, taxes. Late payment interest: 18.5%/year compounded daily."
      ]
    },
