{
  "tables": [
    {
      "id": "T06_01",
      "item": 6,
      "title": "Other Fees — Ongoing Fees",
      "source_pages": [32, 33, 34, 35, 36, 37, 38, 39, 40],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Royalty", "amount": "6% of weekly Gross Sales", "due": "Wednesday each week", "remarks": "Gross Sales defined; excludes taxes, JJ gift card sales, reduced by refunds/credits"},
        {"fee": "Advertising & Development Fund", "amount": "Up to 4.5% weekly GS (currently 4.5%); 2.25% Non-Traditional", "due": "Wednesday each week", "remarks": "See Item 11"},
        {"fee": "Cooperative Advertising", "amount": "Up to 2% of Gross Sales", "due": "As cooperative directs", "remarks": "See Item 11"},
        {"fee": "Successor Franchise", "amount": "$10,000", "due": "Upon renewal", "remarks": ""},
        {"fee": "Site Design/Kitchen Layout", "amount": "$1,200 PSL / $750-$1,200 PKL", "due": "Upon request", "remarks": "PSL only for drive-thru locations"},
        {"fee": "Training (additional)", "amount": "$1,500/person ($2,000 expelled re-attending); may increase to $5,000", "due": "Upon registration", "remarks": "2 free for initial training; 3 for first-time franchisees"},
        {"fee": "New Training/Additional Support", "amount": "$400-$600/person/day + expenses; may increase to $1,000", "due": "When begins", "remarks": ""},
        {"fee": "District Manager Training", "amount": "$2,000; may increase to $5,000", "due": "Upon registration", "remarks": ""},
        {"fee": "Controlling Transfer", "amount": "$2,500 / $7,500 / $12,500", "due": "½ upon request, balance before transfer", "remarks": "$12,500 new franchisee; $7,500 existing; $2,500 family"},
        {"fee": "Non-Controlling Transfer", "amount": "$1,000", "due": "Before proposed effective date", "remarks": ""},
        {"fee": "Product & Service Purchases", "amount": "See Item 8", "due": "As incurred", "remarks": ""},
        {"fee": "Testing", "amount": "Cost of testing", "due": "When billed", "remarks": "For new products/suppliers"},
        {"fee": "Relocation", "amount": "$2,500 + costs", "due": "As incurred", "remarks": ""},
        {"fee": "Computer Systems/Maintenance", "amount": "Costs of service", "due": "As incurred", "remarks": "May charge in future"},
        {"fee": "Franchisee Convention", "amount": "Up to $500", "due": "When billed", "remarks": "Plus travel/living expenses"},
        {"fee": "Regional Advisory Council", "amount": "Council assessments", "due": "When billed", "remarks": ""}
      ],
      "contingent_rows": [
        {"fee": "Audit", "amount": "Cost of audit", "due": "15 days after report", "remarks": "If understate >3% or fail to report"},
        {"fee": "Interest", "amount": "1.5%/month or max legal", "due": "When billed", "remarks": "On amounts >7 days late"},
        {"fee": "Non-Approved Opening", "amount": "$2,500/day", "due": "When billed", "remarks": ""},
        {"fee": "Non-Compliance", "amount": "$250-$1,000/deviation", "due": "When billed", "remarks": "$250 first; $500 1st repeat; $1,000 subsequent"},
        {"fee": "Unauthorized Advertising", "amount": "$1,000/occurrence", "due": "When billed", "remarks": ""},
        {"fee": "Late Fee", "amount": "10% of amount due", "due": "When billed", "remarks": ""},
        {"fee": "Manual Replacement", "amount": "$500", "due": "15 days after billing", "remarks": ""},
        {"fee": "Management Fee", "amount": "$600/person/day + expenses", "due": "As incurred", "remarks": "Death/disability/default/abandonment"},
        {"fee": "Liquidated Damages", "amount": "Up to 36 months × avg monthly royalty", "due": "15 days after termination", "remarks": "On cause termination only"},
        {"fee": "Maintenance Reimbursement", "amount": "$600/day + costs", "due": "As incurred", "remarks": "Sub-standard condition correction"},
        {"fee": "Customer Complaint Reimb.", "amount": "Out-of-pocket cost", "due": "As incurred", "remarks": ""},
        {"fee": "Insurance Reimb.", "amount": "Out-of-pocket cost", "due": "As incurred", "remarks": ""},
        {"fee": "Tax Reimb.", "amount": "Out-of-pocket cost", "due": "As incurred", "remarks": ""},
        {"fee": "De-identification Reimb.", "amount": "Out-of-pocket cost", "due": "As incurred", "remarks": ""},
        {"fee": "Costs & Attorneys' Fees", "amount": "Varies", "due": "As incurred", "remarks": ""},
        {"fee": "Indemnification", "amount": "Varies", "due": "As incurred", "remarks": ""}
      ],
      "table_notes": [
        "All fees non-refundable. Royalty may be negotiated for certain Non-Traditional Locations.",
        "EDTA auto-debit required for all fees. May debit 120% of prior week if Gross Sales not reported.",
        "Multi-Brand Locations: additional fees under Other Franchisor agreements."
      ]
    },
