    {
      "id": "item6_fee_table",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [14, 15, 16, 17, 18],
      "columns": ["Name of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Royalty", "amount": "7% of Gross Revenues; minimum monthly $0 (yr1) to $2,328 (yr5)", "due_date": "10th business day of next month", "remarks": "Greater of 7% or minimum"},
        {"fee": "Brand Fee", "amount": "4% of Gross Revenues", "due_date": "Same as Royalty", "remarks": "Promotion and advertising fund"},
        {"fee": "IT Fee", "amount": "$5.50 per inspection", "due_date": "10th business day of next month", "remarks": "OnePoint software access"},
        {"fee": "Inspection Numbers", "amount": "$28.50 each", "due_date": "As purchased (typically 20 at a time)", "remarks": "Electronic inspection presentation/storage"},
        {"fee": "Financial Reporting Fee", "amount": "$30.00/month", "due_date": "10th business day each month", "remarks": "Qvinci/QuickBooks integration"},
        {"fee": "EZBook Connections", "amount": "$33.45/booking ($29.75 if 90%+ booked)", "due_date": "10th business day of next month", "remarks": "Optional but 80% minimum if elected"},
        {"fee": "PTP360", "amount": "$3.10 per inspection", "due_date": "10th business day of next month", "remarks": "360 photo software"},
        {"fee": "PTPFloorplan", "amount": "$21-$350 by house size", "due_date": "10th business day of next month", "remarks": "36% of customers purchased Prestige in 2024"},
        {"fee": "PTPVirtualOpenHouse", "amount": "$10.00 each", "due_date": "10th business day of next month", "remarks": "Additional service"},
        {"fee": "PTPHomeManual", "amount": "$9.45 each", "due_date": "10th business day of next month", "remarks": "Included with each inspection"},
        {"fee": "Brand Conference Fee", "amount": "$900-$1,200/year", "due_date": "12 monthly installments", "remarks": "Mandatory, non-refundable"},
        {"fee": "Transfer Fee", "amount": "$4,000", "due_date": "Prior to transfer", "remarks": ""},
        {"fee": "Referral Fee", "amount": "$15,000", "due_date": "At closing", "remarks": "If franchisor referred transferee"},
        {"fee": "Renewal Fee", "amount": "$2,500", "due_date": "6 months prior to renewal", "remarks": "Administrative fee"},
        {"fee": "Audit", "amount": "Cost of audit + underpayment + 18% interest", "due_date": "30 days after billing", "remarks": "Only if >2% underreporting"},
        {"fee": "Entity Transfer", "amount": "$1,000", "due_date": "Prior to transfer", "remarks": "Unless within 6 months of signing"},
        {"fee": "Late Payment Interest", "amount": "18% per annum", "due_date": "Immediately", "remarks": ""},
        {"fee": "Attorneys' Fees", "amount": "Variable", "due_date": "As incurred", "remarks": ""},
        {"fee": "Indemnification", "amount": "Variable", "due_date": "As incurred", "remarks": ""}
      ],
      "table_notes": [
        "All fees paid to franchisor. All uniformly imposed. None refundable.",
        "EFT required for all continuing fees.",
        "Fees may be changed/increased upon 90 days notice, max 1 adjustment per calendar year.",
        "Minimum royalty applies only to initial 5-year term."
      ]
    },
