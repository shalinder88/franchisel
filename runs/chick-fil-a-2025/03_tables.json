    {
      "table_id": "T02_item6_other_fees",
      "title": "Other Fees",
      "item_number": 6,
      "page_start": 24,
      "page_end": 24,
      "diligence_family": "fee_stack",
      "column_headers": [
        "Type of Fee",
        "Amount",
        "Due Date",
        "Remarks"
      ],
      "rows": [
        {
          "type_of_fee": "License Fee",
          "amount": "10% of Gross Receipts",
          "due_date": "Monthly, by the 25th day of each month, for the preceding month",
          "remarks": "All new Licensed Units to be located in transportation venues will pay 7% of Gross Receipts, rather than 10% of Gross Receipts"
        },
        {
          "type_of_fee": "Additional Training",
          "amount": "$250 - $400 per employee",
          "due_date": "At least 10 days prior to 1st day of training program",
          "remarks": "There is no training fee for your first 2 employees to be trained."
        },
        {
          "type_of_fee": "Handling Fee",
          "amount": "8% of the purchase price for your equipment and/or signage",
          "due_date": "As incurred",
          "remarks": "If you purchase the equipment or signage through us, you must pay us this fee to cover the administrative costs of our equipment vendor."
        },
        {
          "type_of_fee": "Audit",
          "amount": "Total amount of any underpayment plus 12% per annum interest",
          "due_date": "Within 30 days of notification",
          "remarks": "If audit discloses understatement of 5% or more, you must also pay all of CFA's costs of the audit."
        },
        {
          "type_of_fee": "Indemnification",
          "amount": "Will vary under the factual circumstances",
          "due_date": "As incurred",
          "remarks": "You must reimburse us if we are held liable for claims arising from your Licensed Unit's operations."
        },
        {
          "type_of_fee": "Late Payment Charge",
          "amount": "12% per annum interest on all amounts 30 days overdue",
          "due_date": "As incurred",
          "remarks": ""
        }
      ],
      "table_notes": [
        "1. All fees are imposed by and payable to Chick-fil-A. All fees are non-refundable and are imposed uniformly except as expressly provided in this Item 6. Chick-fil-A's bank accounts, which may contain fees paid by you from time to time, are not trust funds and Chick-fil-A is not your fiduciary.",
        "2. \"Gross Receipts\" includes all cash and charge sales of every kind made at or from or related to the Chick-fil-A Licensed Units except refunds to customers and meals given your employees incident to their employment.",
        "3. Training fee does not include travel, room, living and other expenses, wages or workers compensation coverage for your employees.",
        "4. If an audit discloses an understatement of 5% or more, you must also pay all of Chick-fil-A's costs of the audit."
      ],
      "status": "full",
      "reason_if_partial": null
    },
