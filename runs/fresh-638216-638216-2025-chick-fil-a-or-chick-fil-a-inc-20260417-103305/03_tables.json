      "id": "item6_fees",
      "item": "6",
      "title": "Other Fees",
      "source_pages": [24],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "License Fee", "amount": "10% of Gross Receipts", "due_date": "Monthly, by 25th of each month", "remarks": "Transportation venues pay 7% instead of 10%"},
        {"fee": "Additional Training", "amount": "$250-$400 per employee", "due_date": "At least 10 days prior to 1st day of training", "remarks": "No fee for first 2 employees to be trained per new site"},
        {"fee": "Handling Fee", "amount": "8% of equipment/signage purchase price", "due_date": "As incurred", "remarks": "Covers admin costs of CFA equipment vendor"},
        {"fee": "Audit", "amount": "Underpayment + 12% p.a. interest", "due_date": "Within 30 days of notification", "remarks": "If 5%+ understatement, also pay all CFA audit costs"},
        {"fee": "Indemnification", "amount": "Varies", "due_date": "As incurred", "remarks": "Claims from Licensed Unit operations"},
        {"fee": "Late Payment Charge", "amount": "12% p.a. on amounts 30+ days overdue", "due_date": "As incurred", "remarks": ""}
      ],
      "table_notes": [
        "1. All fees imposed by and payable to Chick-fil-A. All fees non-refundable and uniformly imposed except as noted.",
        "2. Gross Receipts includes all cash and charge sales from Licensed Units except refunds and employee meals incident to employment.",
        "3. Training fee does not include travel, room, living expenses, wages, or workers comp coverage.",
        "4. If audit discloses 5%+ understatement, must also pay all CFA audit costs."
      ],
      "provenance": "Extracted from Item 6 fee table, page 24"
    },
