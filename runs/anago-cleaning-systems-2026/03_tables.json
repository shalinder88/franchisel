    {
      "table_id": "item6_other_fees",
      "source_item": "Item 6",
      "source_pages": [14, 15, 16, 17, 18, 19, 20, 21],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Royalty Fee", "amount": "5% of Gross Revenues", "due_date": "Monthly, 20th", "remarks": "Escalating minimums: months 1-12=$0; months 13-24=$1,500/mo; then +$1,500/year. Successor agreement min = avg of last year's royalty. Gross Revenues defined broadly — all amounts from client services."},
        {"type": "Training Fees", "amount": "$500/day", "due_date": "As incurred", "remarks": "Only if unsatisfactory audit or failed training requires refresher/retraining"},
        {"type": "Administrative Support Fee", "amount": "2% of Gross Revenues", "due_date": "Monthly, 20th", "remarks": "Continued advisory, franchise promotion, lead referral, NBDS support phone/email"},
        {"type": "Billing and Collection Fees", "amount": "Greater of $1,000 or 1% of Gross Revenues + $25/unit franchise statement", "due_date": "Monthly, 20th", "remarks": "Only after Event of Default or at franchisee request"},
        {"type": "Deficiencies", "amount": "Reimbursement of costs", "due_date": "Immediately upon invoice", "remarks": "If franchisor performs franchisee obligations"},
        {"type": "NBDS Support/Access Fees", "amount": "Currently $550/month", "due_date": "Monthly upon invoice", "remarks": "Proprietary software; subject to change; not refundable"},
        {"type": "Website Maintenance Fee", "amount": "Currently $1,500/month", "due_date": "Monthly, 20th", "remarks": "Only if franchisor assumes website responsibility"},
        {"type": "Technology Fee", "amount": "Up to 1.5% of Gross Revenues", "due_date": "Monthly, 20th", "remarks": "Not currently assessed; for hardware/software development/license"},
        {"type": "Transfer Fee", "amount": "$10,000", "due_date": "At time of transfer", "remarks": "In lieu of Initial Fee; no fee for spouse/child transfers"},
        {"type": "Replacement of Manuals", "amount": "$500", "due_date": "As incurred", "remarks": "Initial set free; replacement if lost"},
        {"type": "Indemnification", "amount": "Varies", "due_date": "Immediately upon invoice", "remarks": "Broad coverage: operations, Unit Franchise Agreement nonperformance, negligence, law violations, breach, joint employer claims"},
        {"type": "Enforcement Costs", "amount": "Varies", "due_date": "Immediately upon invoice", "remarks": "Prevailing party gets attorneys fees; includes pre-litigation enforcement costs"},
        {"type": "Miscellaneous Merchandise", "amount": "Varies", "due_date": "Immediately upon invoice", "remarks": "Optional branded items; cannot create own branded items without consent"},
        {"type": "Sale of Unit Franchise Fee", "amount": "$400 per Unit Franchise sold", "due_date": "Upon sale", "remarks": "Per-unit fee"},
        {"type": "Client Bid Schedule Deficiency Fee", "amount": "$150 per missed bid", "due_date": "January each year (or Jan+Jul)", "remarks": "If below minimum monthly Client Bids; minimums vary by Area population"},
        {"type": "Banking Fees", "amount": "4.75% per CC transaction", "due_date": "Monthly", "remarks": "Optional; franchisor CC processing; may exceed actual bank charges"},
        {"type": "Client Marketing Spend", "amount": "Minimum $50,000/year", "due_date": "Immediately upon invoice", "remarks": "Shortfall paid to franchisor; prorated for partial years"},
        {"type": "Advertising Fund", "amount": "Up to 2.2% of Gross Revenues", "due_date": "When invoiced", "remarks": "Not currently collected; Fund not audited; not asset of AFI"},
        {"type": "Supplier Testing Fee", "amount": "Reasonable costs of inspection + actual testing cost", "due_date": "Immediately upon invoice", "remarks": "If proposing unapproved supplier"}
      ],
      "table_notes": [
        "Note 1: Unless otherwise indicated, all fees are nonrefundable and are imposed and collected by us.",
        "Note 2: All fees payable to us or our designee.",
        "Note 3: We may accept from your Anago Escrow Account any amounts we are owed under the Subfranchise Rights Agreement.",
        "Note 4: Currently $550/month for NBDS access support services; subject to change.",
        "Note 5: Client Bid minimums by population: ≤1M pop = 15/20/25 bids per month (yr1/yr2/yr3+); 1-3M pop = 20/30/40; ≥3M pop = 30/45/60."
      ]
    },
