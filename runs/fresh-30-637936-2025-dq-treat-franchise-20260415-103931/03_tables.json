    {
      "id": "T17-1",
      "item": 17,
      "title": "The Franchise Relationship — Renewal, Termination, Transfer, Dispute Resolution",
      "source_pages": [53, 54, 55, 56],
      "columns": ["Provision", "Section", "Summary"],
      "rows": [
        {"Provision": "Length of term", "Section": "4.1", "Summary": "15 years (new); lesser of 15 years or remaining term (transfer); renewal term from expiring agreement (renewal)"},
        {"Provision": "Renewal", "Section": "4.3", "Summary": "One additional term: shorter of 15 years or remaining lease term"},
        {"Provision": "Renewal requirements", "Section": "4.3", "Summary": "Notice 3-6 months before; sign then-current agreement (may differ materially, higher fees); modernize; good standing; right to premises; pay renewal fee; sign release"},
        {"Provision": "Termination by franchisee", "Section": "13.3", "Summary": "For material breach after 30-day notice to cure; effective 60 days after notice"},
        {"Provision": "Termination by franchisor with cause", "Section": "13.2", "Summary": "If franchisee defaults"},
        {"Provision": "Curable defaults", "Section": "13.1, 13.2(A-B)", "Summary": "24 hours (goodwill/health/safety); 10 days (reports/payments); 30 days (all other)"},
        {"Provision": "Non-curable defaults", "Section": "13.1, 13.2(C)", "Summary": "Lose premises, failure to reopen, abandonment, insolvency, conviction, intentional underreporting, 3rd default in 12 months, OFAC designation"},
        {"Provision": "Obligations on termination", "Section": "13.2(D), 14", "Summary": "Stop using marks; pay amounts due; comply with noncompete; maintain confidentiality; pay termination fee"},
        {"Provision": "Assignment by franchisor", "Section": "11.6", "Summary": "No restriction"},
        {"Provision": "Transfer defined", "Section": "11.2", "Summary": "Restaurant, assets, revenues, ownership interest, or management agreement"},
        {"Provision": "Franchisor approval of transfer", "Section": "11.1, 11.4", "Summary": "Consent required; not unreasonably withheld if all requirements met"},
        {"Provision": "Transfer conditions", "Section": "11.3", "Summary": "Transferee qualifies; pay $6,000 fee; amounts paid; compliance; guarantee; release; training; sign then-current agreement (may differ materially); facility improvements; post-term obligations"},
        {"Provision": "Right of first refusal", "Section": "11.3(B)", "Summary": "ADQ can match offer to purchase; appraiser sets price in insolvency"},
        {"Provision": "Purchase option", "Section": "14.5", "Summary": "On termination/expiration, ADQ may purchase restaurant assets; appraiser determines price"},
        {"Provision": "Death or disability", "Section": "11.2", "Summary": "Must comply with all transfer requirements"},
        {"Provision": "In-term noncompete", "Section": "10.5", "Summary": "No involvement in QSR serving hamburgers (no alcohol) or business with >10% revenue from ice cream/yogurt/frozen custard/fruit beverages/soft-serve/frozen treats"},
        {"Provision": "Post-term noncompete", "Section": "14.6", "Summary": "1 year after termination/expiration; within 500 meters (Street) or same building/venue (Captive-venue)"},
        {"Provision": "Modification", "Section": "6.1, 6.11, 15.4", "Summary": "Must be signed by both parties; but ADQ can change menu, Operations Manual, and trademarks unilaterally"},
        {"Provision": "Integration/merger", "Section": "15.2", "Summary": "Franchise agreement + addenda + application = sole agreement (subject to state law). Does not disclaim FDD representations."},
        {"Provision": "Arbitration", "Section": "12", "Summary": "Most disputes: arbitration in Minneapolis, MN or mutually agreed place (subject to state law)"},
        {"Provision": "Choice of forum", "Section": "15.9", "Summary": "Federal District Court for District of MN or Hennepin County District Court, Minneapolis (subject to state law)"},
        {"Provision": "Choice of law", "Section": "15.8", "Summary": "Law of state where authorized location is situated"}
      ],
      "table_notes": []
    },
