  "tables": [
    {
      "id": "T5-1",
      "item": 5,
      "title": "Initial Fees Summary",
      "source_pages": [20],
      "columns": ["Fee", "Amount", "Refundability"],
      "rows": [
        {"Fee": "Initial Franchise Fee", "Amount": "$25,000", "Refundability": "Partially refundable — $10,000 deposit non-refundable; balance refundable under 4 specified conditions"},
        {"Fee": "MTRA Fee", "Amount": "$200 per attendee per attempt", "Refundability": "Non-refundable (may be applied to next MTRA if cancelled >1 business day before)"}
      ],
      "table_notes": ["No initial franchise fee for conversions, relocations, or OJ conversions. Reduced fee may apply for reopened locations, certain captive-venues, and qualifying multi-unit operators."]
    },
    {
      "id": "T6-1",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [21, 22, 23, 24],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Type of Fee": "Continuing License Fee", "Amount": "5% of Gross Sales", "Due Date": "10th of each month", "Remarks": "May be reduced for specialty captive-venue locations. Conversions/relocations may have different rates."},
        {"Type of Fee": "Sales Promotion Program Fee", "Amount": "Up to 6% of Gross Sales (OJ branded); 5%-6% of Gross Sales (all other)", "Due Date": "10th of each month", "Remarks": "ADQ determines percentage within range. 90 days notice of changes. Street OJ: 5%; Captive-venue OJ: 1.25%."},
        {"Type of Fee": "Lease-Required Sales Promotion Fees", "Amount": "Varies", "Due Date": "When due", "Remarks": "Additional to SPF per lease requirements."},
        {"Type of Fee": "Transfer Fee", "Amount": "$6,000", "Due Date": "With transfer application", "Remarks": "Increases $500 every 5 years starting Jan 1, 2030. Refundable if ADQ refuses or exercises ROFR (less actual costs)."},
        {"Type of Fee": "Renewal Fee", "Amount": "$1,000 × years of renewal term (max $10,000)", "Due Date": "At time of renewal", "Remarks": "Partial year counts as full year."},
        {"Type of Fee": "Audit and Recordkeeping Costs", "Amount": "CLF% + SPF% × understated Gross Sales + audit costs", "Due Date": "After audit revealing ≥3% understatement", "Remarks": "Includes salaries, accountant fees, attorney fees, copying, travel, meals, lodging. Plus costs of any additional audits within 2 years."},
        {"Type of Fee": "Termination Fee", "Amount": "2× last 12 months CLF (or prorated formulas)", "Due Date": "Upon termination", "Remarks": "Applies on default termination. Three calculation methods depending on operating history."},
        {"Type of Fee": "Interest Expenses", "Amount": "18% per annum or max legal rate", "Due Date": "When due", "Remarks": "On past-due payments."},
        {"Type of Fee": "Late Fees", "Amount": "$50 per delinquent report or payment", "Due Date": "When due", "Remarks": "Per occurrence."},
        {"Type of Fee": "Additional Training Fees", "Amount": "Varies", "Due Date": "When incurred", "Remarks": "For replacement managers."},
        {"Type of Fee": "Gift Card Program Fees", "Amount": "3% of total gift card redemptions", "Due Date": "When incurred", "Remarks": "~$200/year/location. Shared cost model with NMF."},
        {"Type of Fee": "Costs and Attorneys' Fees", "Amount": "Varies", "Due Date": "When incurred", "Remarks": "For enforcement of franchise agreement."},
        {"Type of Fee": "Training Materials", "Amount": "$150-$500", "Due Date": "As materials provided", "Remarks": "Periodic required purchase."},
        {"Type of Fee": "Training Cancellation/Substitution Fee", "Amount": "$100-$1,000", "Due Date": "Upon cancellation or substitution", "Remarks": "$150 (phase 1-2, >14 days); $750 (phase 1-2, ≤14 days); $1,000 (phase 3, ≤21 days). Substitution: $200."}
      ],
      "table_notes": [
        "(1) Except where otherwise noted, all fees are payable to ADQ or its affiliates, uniformly imposed, and nonrefundable.",
        "(2) Conversion and relocation franchisees may have different CLF rates. Pre-April 2007 renewal with 6% CLF: remains at 6% until modernization complete, then 5%.",
        "(3) Conversion SPF rates vary: soft-serve only conversion 3%, NSF conversion ≥2.5%. Relocation phases in: years 1-5 carry over, years 6-10 ≥3.5-4%, year 11+ standard 5-6%.",
        "(4) See Item 11 for training details and Item 7 footnote 5.",
        "(5) Late payers may be required to remit via weekly payment program. ADQ may pay franchisee's debts and demand immediate reimbursement."
      ]
    },
