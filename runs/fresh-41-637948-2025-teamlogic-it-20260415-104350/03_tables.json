      "title": "Other Fees",
      "columns": ["Fee Type", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Fee Type": "Continuing Franchise Fee (CFF)", "Amount": "7% of Gross Sales; min $1,000/mo after month 12", "Due Date": "Monthly; EFT", "Remarks": "No minimums first 12 months"},
