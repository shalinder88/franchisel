        {"Fee Type": "RMM Managed Services", "Amount": "$3-$6/agent/month", "Due Date": "Monthly; EFT", "Remarks": "Min 3 agents required"},
        {"Fee Type": "Additional Training", "Amount": "$1,000/person", "Due Date": "At time of training", "Remarks": "Beyond 2 people; trainee pays own travel/hotel/meals"},
        {"Fee Type": "Multi-Factor Authentication Tool", "Amount": "$0-$30/month", "Due Date": "Monthly", "Remarks": "Paid to various vendors"},
        {"Fee Type": "Software & Technology - PSA Tools", "Amount": "$175-$225/month", "Due Date": "Monthly", "Remarks": "Payable to franchisor and vendors"},
        {"Fee Type": "Software & Technology - Anti-Virus", "Amount": "$1-$2/month", "Due Date": "Monthly", "Remarks": ""},
        {"Fee Type": "Software & Technology - Office Suite", "Amount": "$35/month", "Due Date": "Monthly", "Remarks": ""},
        {"Fee Type": "Software & Technology - Email Service", "Amount": "$24/user/month", "Due Date": "Monthly", "Remarks": ""},
        {"Fee Type": "Software & Technology - QuickBooks Online", "Amount": "$100-$150/month", "Due Date": "Monthly", "Remarks": ""},
        {"Fee Type": "Software & Technology - Process Automation", "Amount": "$150/month", "Due Date": "Monthly", "Remarks": ""},
        {"Fee Type": "Transfer Fee", "Amount": "$10,000", "Due Date": "Before transfer", "Remarks": "No charge for immediate family actively participating"},
        {"Fee Type": "Audit Fee", "Amount": "$0-$3,500", "Due Date": "On demand", "Remarks": "Only if >2% understatement for any 2-month period"},
        {"Fee Type": "Late Payment Interest", "Amount": "10%/year or max legal rate", "Due Date": "As incurred", "Remarks": "On fees >5 days late"},
        {"Fee Type": "Late Fee", "Amount": "$250 + 1.5%/month interest", "Due Date": "On demand", "Remarks": ""},
        {"Fee Type": "Failure to Report Sales", "Amount": "$250/week", "Due Date": "On demand", "Remarks": ""},
        {"Fee Type": "Insufficient Funds Fee", "Amount": "$250", "Due Date": "On demand", "Remarks": ""},
        {"Fee Type": "Collection Costs", "Amount": "Actual costs", "Due Date": "As incurred", "Remarks": "Including reasonable attorney fees"},
        {"Fee Type": "Renewal Fee", "Amount": "$2,000", "Due Date": "At renewal signing", "Remarks": "Must be in full compliance"},
        {"Fee Type": "Custom Domain Names", "Amount": "$0-$40/year", "Due Date": "As appropriate", "Remarks": "Owned by franchisor"},
