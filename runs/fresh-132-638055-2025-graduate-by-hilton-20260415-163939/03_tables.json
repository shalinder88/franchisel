        {"type": "Hilton Core Sales Skills Training", "amount": "Up to $600/attendee", "due": "Before attendance", "remarks": ""},
        {"type": "Other Training Programs", "amount": "Up to $5,000/program/attendee", "due": "Before attendance", "remarks": ""},
        {"type": "Travel Clubs (AAA/CAA)", "amount": "$0.30/available room + 10% commission", "due": "Annually + monthly", "remarks": ""},
        {"type": "Hilton Advance Program", "amount": "1.35% of eligible Digital Direct Revenue, max $30/stay", "due": "Within 15 days or 12th business day", "remarks": ""},
        {"type": "Group Preferred Partnership", "amount": "Up to $1.80/consumed room night + commission", "due": "Within 15 days or 12th business day", "remarks": "Optional; may increase to $2.50"},
        {"type": "Hilton Honors", "amount": "4.3% of total eligible guest folio", "due": "10 days after billing", "remarks": "Waived for on-property enrollments"},
        {"type": "Hilton Honors Event Planner Bonus", "amount": "$0.0025–$0.0050/bonus point", "due": "As incurred", "remarks": "Auto-enrolled, may opt out"},
        {"type": "Hilton For Business Program", "amount": "Up to 3% of GRR per eligible stay", "due": "As incurred", "remarks": "Auto-enrolled, may opt out annually"},
        {"type": "Online Group Event Booking", "amount": "Up to 2% of Booked Reservation Charges + up to 5% Groups360 commission", "due": "On demand", "remarks": "Currently optional, may become required"},
        {"type": "Centralized Payment — Third-Party Reservation Charges", "amount": "Up to $5.93/stay", "due": "Monthly", "remarks": "GDS, airline, internet reservations"},
        {"type": "Centralized Payment — FastPay", "amount": "Up to $1.40/transaction + commission", "due": "Monthly", "remarks": "Group intermediaries and meeting planners"},
        {"type": "Centralized Payment — TPCP", "amount": "$0.18/transaction + up to 10% commission", "due": "Monthly", "remarks": "Travel planner payments"},
        {"type": "Centralized Payment — Unlimited Rewards", "amount": "$0.71–$3.84/stay", "due": "Monthly", "remarks": "Travel advisor incentive (Avis Budget)"},
        {"type": "Add-On Program Fee", "amount": "Up to 5% of Add-On sale price", "due": "As incurred", "remarks": "Not applied if subject to Royalty/Program Fee"},
        {"type": "Change of Ownership Application Fee", "amount": "$150,000", "due": "With Application", "remarks": ""},
        {"type": "Permitted Transfer Processing Fee", "amount": "$5,500", "due": "With request", "remarks": ""},
        {"type": "Re-licensing Application Fee", "amount": "$100,000", "due": "With Application", "remarks": ""},
        {"type": "Lender Comfort Letter", "amount": "$3,500 (letter) / $1,500 (assignment)", "due": "Before issuance", "remarks": ""},
        {"type": "Public Offering Processing Fee", "amount": "$5,000", "due": "With request", "remarks": "Plus additional costs/attorneys' fees"},
        {"type": "Liquidated Damages — Pre-Opening", "amount": "$11,200 × approved rooms", "due": "On demand", "remarks": "If terminated before opening"},
        {"type": "Liquidated Damages — Post-Opening (before 2nd anniversary)", "amount": "Greater of: (Avg Monthly Royalty × 60) or ($11,200 × rooms)", "due": "On demand", "remarks": ""},
        {"type": "Liquidated Damages — Post-Opening (after 2nd anniv, before final 60 months)", "amount": "Avg Monthly Royalty × 60", "due": "On demand", "remarks": ""},
        {"type": "Liquidated Damages — Post-Opening (final 60 months)", "amount": "Avg Monthly Royalty × months remaining", "due": "On demand", "remarks": ""},
        {"type": "Service Charges for Overdue Payments", "amount": "1.5%/month", "due": "On demand", "remarks": "Or highest rate permitted by law"},
        {"type": "Identity/Sales/Distribution Non-Compliance", "amount": "$500/instance", "due": "On demand", "remarks": ""},
        {"type": "FastPay Non-Compliance", "amount": "$500–$3,000/violation", "due": "On demand", "remarks": "Escalating based on violations"},
        {"type": "Consortia Program", "amount": "Up to $3.00/consumed room night + up to 10% commission", "due": "Within 15 days or 12th business day", "remarks": "Must participate in 3 programs simultaneously"},
        {"type": "TMC Pay-On-All-Pay-For Performance", "amount": "Up to $1.85/consumed room night + up to 10% commission", "due": "Within 15 days or 12th business day", "remarks": ""},
        {"type": "TMC Small Business (SMB)", "amount": "Up to $1.85/consumed night + up to 10% commission", "due": "Within 15 days or 12th business day", "remarks": ""},
        {"type": "US Government Travel Agency Programs", "amount": "Up to $2.30/room night or 1.45% consumed room revenue; FedRooms/DOD: 2.25%", "due": "Monthly", "remarks": "Optional"},
        {"type": "ResMax Program", "amount": "5.4%–5.9% of consumed revenue (3-night max)", "due": "As required", "remarks": "Optional supplemental reservation service"},
        {"type": "RMCC (ongoing)", "amount": "$835–$15,709/month depending on category", "due": "Within 10 days", "remarks": "Optional except for expedited openings"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due": "As agreed", "remarks": ""}
      ],
      "table_notes": [
        "Note 1: GRR includes all room revenue, redemption points, breakfast bundled, Mandatory Guest Fee, late cancellation, no-show revenue. Group rebates included.",
        "Note 2: Monthly Program Fee may increase up to +1% of GRR over the term. Funds reservation systems, directories, advertising, promotion, quality assurance, technology.",
        "Note 3: Multiple quality assurance fees may stack. PIP/Renovation Failure and Service Quality Improvement fees apply in addition to other QA fees.",
        "Note 5: Sales and distribution programs may be added, removed, or modified at any time.",
        "Note 6: Hilton Honors 4.3% on eligible folio. Additional bonus points from promotions result in additional per-point or percentage fees.",
        "Note 8: Avg Monthly Royalty = total royalty for 24-month measurement period ÷ 24 (or shorter if open <24 months). Excludes temporary financial accommodations and business interruptions.",
        "Note 9: RMCC mandatory for expedited openings: Intermediate Model if >$6M annual GRR; Premier Model if >$10M annual GRR or dynamic market."
      ],
      "provenance": "Item 6, pages 27–39 (FDD pages 19–31)"
    },
