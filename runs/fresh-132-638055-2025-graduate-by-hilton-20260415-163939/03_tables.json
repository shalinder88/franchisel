  "tables": [
    {
      "id": "T01_item5_initial_fees",
      "item": 5,
      "title": "Initial Fees",
      "source_pages": [22, 23, 24, 25, 26],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Franchise Application Fee — New Dev/Conversion", "amount": "$100,000 + $400/room over 250", "due": "With Application", "remarks": "Non-refundable once approved; $7,500 processing fee if denied/withdrawn"},
        {"type": "Franchise Application Fee — Change of Ownership", "amount": "$150,000", "due": "With Application", "remarks": "Non-refundable once approved"},
        {"type": "Franchise Application Fee — Re-licensing", "amount": "$100,000", "due": "With Application", "remarks": "Non-refundable once approved"},
        {"type": "PIP Fee", "amount": "$10,000", "due": "Before PIP inspection", "remarks": "For Conversion, COO, or Re-licensing"},
        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due": "With written request", "remarks": "Per extension request"},
        {"type": "OnQ Computer System (Hardware/Software/Install)", "amount": "$118,350–$273,450", "due": "As agreed", "remarks": "Based on hotel size and workstation count"},
        {"type": "Other Initial Start-Up Fees", "amount": "$6,500", "due": "Before opening", "remarks": "GRO setup, Digital Floor Plan, Opening Transition Tool"},
        {"type": "Training Program Fees", "amount": "$5,000–$15,000", "due": "As agreed", "remarks": "GM and key personnel pre-opening training"},
        {"type": "Opening Process Services Fee", "amount": "$20,000", "due": "Before opening", "remarks": "Pre-opening services (commercial planning, activation)"},
        {"type": "RMCC Pre-Opening Support", "amount": "$4,059–$8,880", "due": "Within 10 days of billing", "remarks": "May be required for expedited openings (≤150 days)"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due": "As agreed", "remarks": "If purchased through HSM"},
        {"type": "Miscellaneous Services", "amount": "As agreed", "due": "As agreed", "remarks": "Optional additional services"}
      ],
      "table_notes": [
        "Note 1: Refund of $7,500 processing fee if application withdrawn or denied. Non-refundable once approved. Fee may be reduced for incentives, market position, property size, multi-unit.",
        "Note 2: New Dev must start construction within 16 months. Automatic 30-day rolling extensions for New Dev/Conversion unless 60-day notice given.",
        "Note 3: Must use OnQ system. OnQ software proprietary to HSS. Must refresh every 3 years. Also requires GRO, Delphi, Connected Room, Digital Floor Plan, Digital Key, Opening Transition Tool.",
        "Note 4: HSM procurement fees 4%–10% of project cost, plus freight, sales tax, actual costs. 18.5%/year interest on late payments."
      ],
      "provenance": "Item 5, pages 22–26 (FDD pages 14–18)"
    },
