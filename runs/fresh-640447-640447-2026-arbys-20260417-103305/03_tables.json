      "title": "Development Fee and Franchise Fee Schedule",
      "source_pages": [29],
      "columns": ["Franchise Offers", "Development Fee per Restaurant", "Franchise Fee per Restaurant"],
      "rows": [
        {"offer": "Standard Traditional Restaurant", "dev_fee": "$12,500", "franchise_fee": "$37,500"},
        {"offer": "Non-Traditional Restaurant", "dev_fee": "$0", "franchise_fee": "$18,750"},
        {"offer": "Standard Incentive", "dev_fee": "$12,500", "franchise_fee": "$0"}
      ],
      "table_notes": ["Fees are uniform, fully earned when paid, and not refundable."]
    },
    {
      "id": "item6_fee_table",
      "item": "6",
      "title": "Other Fees",
      "source_pages": [31, 32, 33, 34],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Royalty Fee", "amount": "4% of Gross Sales (Traditional); 6.2% (Non-Traditional)", "due": "Monthly, 10th of following month", "remarks": "Subject to incentive reductions"},
        {"fee": "Advertising and Marketing Service Fee", "amount": "Minimum aggregate 5.2% including Local Market and Co-op; AFA rate 3.22%–5.0%", "due": "Same as Royalty", "remarks": "AFA franchisee organization; we pay from royalty for Non-Traditional"},
        {"fee": "Renewal Fee", "amount": "10% of then-applicable franchise fee (Traditional); Non-Traditional franchise fee", "due": "180 days before expiration", "remarks": "Successor FA if criteria met"},
        {"fee": "Transfer Fee (Ownership)", "amount": "$17,500 first restaurant; $2,500 if existing franchisee", "due": "Upon request", "remarks": "Non-refundable; right to approve"},
        {"fee": "Arby's Training Program", "amount": "$2,100/attendee (expected increase to $4,000)", "due": "As incurred", "remarks": "No fee for 2 managers in first restaurant"},
        {"fee": "Learning Management System", "amount": "$62.99/year per restaurant", "due": "Annually", "remarks": "Cornerstone platform"},
        {"fee": "Additional Training", "amount": "$0–$4,000", "due": "As incurred", "remarks": "For failed inspections"},
        {"fee": "Arby's Order Ahead Platform Service Fee", "amount": "$50/month + 4% per transaction (35¢ min, $1.25 max); 3% on 3rd-party delivery", "due": "Same as Royalty", "remarks": "Optional; paid to IRB affiliate; not a profit center"},
        {"fee": "Site Design Fee / Kitchen Layout Design Fee", "amount": "$1,200 PSL; $750 PKL (remodel); $1,200 PKL (new)", "due": "Upon request", "remarks": "PSL only for drive-thru restaurants"},
        {"fee": "Audits", "amount": "Audit expenses + interest", "due": "5 days after demand", "remarks": "If >3% Gross Sales deficiency"},
        {"fee": "Testing of Samples", "amount": "Cost of samples", "due": "As incurred", "remarks": "New product testing"},
        {"fee": "Approval of Suppliers", "amount": "$2,500–$10,000", "due": "As incurred", "remarks": "May pass cost to franchisee"},
        {"fee": "Interest", "amount": "Up to 18% per year", "due": "5-10 days after demand", "remarks": "On all overdue amounts"},
        {"fee": "Costs and Attorneys' Fees", "amount": "Varies", "due": "As incurred", "remarks": "For FA non-compliance"},
        {"fee": "Indemnity", "amount": "Varies", "due": "As incurred", "remarks": "All claims from operations"},
        {"fee": "Insurance", "amount": "Carrier-set premium", "due": "As incurred", "remarks": "Franchisor may obtain if not maintained"}
      ],
      "table_notes": [
        "General Terms: Fees not refundable; paid by EFT. Some franchisees under existing DAs may pay different fees.",
        "Gross Sales definition: Total revenue from all products/services, excluding coupons/discounts and sales tax.",
        "Standard Incentive royalty ramp: 0.5% (Year 1), 1.0% (Years 2-4), 2.0% (Year 5), 4.0% (Year 6+). Additional reduction to 2.0% Years 6-10 if Gross Sales below $1.3M after Year 4.",
        "Relocation Incentive royalty ramp: 1% (Year 1), 2% (Year 2), 3% (Year 3), 4% (Year 4+). $50,000 royalty credit if opened by Dec 31, 2028.",
        "Standard Incentive advertising discount: 75% off Years 1-3, 50% off Year 4, standard Year 5+. Minimum 0.85%.",
        "Local Market and Co-op advertising: minimum 0.2%–1.98% depending on DMA and AFA dues."
      ]
    },
