  "tables": [
    {
      "id": "item5_initial_fees",
      "item": "Item 5",
      "title": "Initial License Fees",
      "source_pages": [18],
      "columns": ["Fee", "Amount", "Notes"],
      "rows": [
        {"fee": "Initial License Fee", "amount": "$25,000", "notes": "Standard for new licensees; non-refundable; payable within 5 days of written authorization"}
      ],
      "table_notes": ["In 2024, actual fees ranged from $12,500 to $25,000. Lower amounts for multi-restaurant licensees under existing agreement terms."]
    },
    {
      "id": "item6_fee_table",
      "item": "Item 6",
      "title": "Other Fees",
      "source_pages": [18, 19, 20, 21, 22, 23],
      "columns": ["Fee", "Amount", "When Payable", "Remarks"],
      "rows": [
        {"fee": "Royalty", "amount": "8% of Gross Volume or $4,000 minimum per Royalty Period", "when_payable": "15th of each month", "remarks": "CPI-adjustable; no min during force majeure; starts with first Royalty Period of operations"},
        {"fee": "Initial Training Fees", "amount": "No fee (up to 8 attendees/restaurant); up to $1,000 per attendee beyond 8", "when_payable": "Before training", "remarks": "$50-$100 for uniforms per attendee; licensee pays all travel/salary/lodging"},
        {"fee": "Opening Operational Assistance", "amount": "$500 per whole/partial 8-hour day", "when_payable": "Before training or as incurred", "remarks": "Plus travel/lodging/food expenses for franchisor personnel"},
        {"fee": "Remedial Training Fees & On-Site Consultations", "amount": "$500 per whole/partial 8-hour day", "when_payable": "Before training or as incurred", "remarks": "CPI-adjustable; plus travel/lodging/food expenses"},
        {"fee": "Online Training/Continuous Education", "amount": "$250-$500", "when_payable": "Before training or as incurred", "remarks": "Varies by number of people trained"},
        {"fee": "Inspections/Quality Control Programs", "amount": "$177.24/quarterly food safety; $20-$22/mo surveys; $19.75-$55 mystery shopper + $11-$12 meal", "when_payable": "As incurred", "remarks": "Ecosure food safety; SMG surveys; Ipsos mystery shop; Refused Entry Fee $177.24"},
        {"fee": "Transfer Fee", "amount": "$10,000 per restaurant + out-of-pocket costs/atty fees (max $30,000 cumulative per transaction)", "when_payable": "Upon application for transfer", "remarks": "Due even if transfer not completed; CPI-adjustable"},
        {"fee": "Inspection or Audit Costs", "amount": "Understated royalties + interest + cost of audit", "when_payable": "On demand", "remarks": "Only if understatement exceeds 3%"},
        {"fee": "Interest on Late Payments/Bank Charges", "amount": "10% per annum or max legal rate; plus bank fees for dishonored payments", "when_payable": "On demand", "remarks": ""},
        {"fee": "Successor Restaurant Fee", "amount": "$10,000 per restaurant", "when_payable": "On successor term election", "remarks": "CPI-adjustable"},
        {"fee": "Management Fees and Costs", "amount": "7% of Gross Volume per restaurant managed + costs", "when_payable": "If franchisor manages due to uncured default", "remarks": "Can discontinue on 10 days' notice"},
        {"fee": "Gift Card Program (optional)", "amount": "$0.09-$0.535/card; $0.0199-$0.032/transaction + support/admin costs", "when_payable": "As incurred if elected", "remarks": "Not currently required"},
        {"fee": "Tax Payments", "amount": "Unknown/variable", "when_payable": "On demand", "remarks": "Reimbursement of taxes paid on licensee's behalf"},
        {"fee": "Early Termination Fee", "amount": "Anticipated royalties for remaining 8-month notice period", "when_payable": "On demand", "remarks": "Based on average daily Gross Revenue times remaining days"},
        {"fee": "Quarterly Promotional Materials", "amount": "$300-$1,000 per year", "when_payable": "As incurred", "remarks": "Must purchase from marketing department"}
      ],
      "table_notes": [
        "All fees non-refundable and payable to Citadel Panda Express, Inc.",
        "Payment by wire transfer, ACH, or other method stated in Manuals.",
        "CPI-adjustable amounts may be adjusted once per year per Consumer Price Index (U.S. Average, all items).",
        "Gross Volume includes all sales and billings — cash, credit, insurance proceeds, third-party delivery — with no deduction except sales tax and customer refunds.",
        "Royalty period is currently a four-week period.",
        "Other licensees may operate under more favorable fee and Proprietary Product markup terms."
      ]
    },
