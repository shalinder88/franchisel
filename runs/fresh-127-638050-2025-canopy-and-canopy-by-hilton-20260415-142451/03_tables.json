      "item": 5,
      "title": "Initial Fees",
      "source_pages": [23, 24, 25],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Franchise Application Fee — New Dev/Conversion", "amount": "$85,000 + $400/room over 250", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee — Change of Ownership", "amount": "$150,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee — Re-licensing", "amount": "$85,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "PIP Fee", "amount": "$10,000", "due_date": "Before PIP inspection scheduled", "remarks": "For Conversion/COO/Re-licensing"},
        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due_date": "With written request", "remarks": "See Note 2"},
        {"type": "OnQ Computer System Fees", "amount": "$113,400 to $276,000", "due_date": "As agreed", "remarks": "See Note 3"},
        {"type": "Other Initial Start Up Fees", "amount": "$6,500", "due_date": "As incurred before opening", "remarks": "GRO, Digital Floor Plan, Opening Transition Tool"},
        {"type": "Restaurant Brand Initial Fee", "amount": "$47,500", "due_date": "When signing Restaurant Brands Amendment", "remarks": "Optional, per brand. See Note 4"},
        {"type": "Training Program Fees", "amount": "$5,000 to $20,000", "due_date": "As agreed", "remarks": "Plus travel/lodging costs"},
        {"type": "Opening Process Services Fee", "amount": "$20,000", "due_date": "Before opening", "remarks": "Pre-opening services"},
        {"type": "Procurement and Services Fees", "amount": "4% to 10% of project cost", "due_date": "As agreed", "remarks": "If using HSM. See Note 5"},
        {"type": "Miscellaneous Services", "amount": "As agreed", "due_date": "As agreed", "remarks": "Optional and mandatory additional services"}
      ],
      "table_notes": [
        "Note 1: Refundable (less $7,500 processing) if denied or withdrawn before approval. In 2024, fees ranged $37,500–$100,000 for New Dev/Conversion.",
        "Note 2: Start construction within 16 months (New Dev). Automatic 30-day rolling extensions for New Dev/Conversion until 60 days notice given.",
        "Note 3: OnQ hardware/software/installation. Refresh every 3 years. HPMS is proprietary. No third-party market for OnQ in entirety.",
        "Note 4: Restaurant Brands are optional. Initial fee per brand. Nonrefundable.",
        "Note 5: HSM procurement fee 4%–10% of project cost plus actual costs and freight."
      ]
    },
