        {"type": "Centralized Payment Programs", "amount": "Various ($0.18–$5.93/transaction)", "due_date": "Within 15 days or ACH", "remarks": "Required. Third-party reservations, FastPay, TPCP, Unlimited Rewards"},
        {"type": "Add-On Program Fee", "amount": "Up to 5% of sale price", "due_date": "As incurred", "remarks": "Currently optional"},
        {"type": "Change of Ownership Application Fee", "amount": "$150,000", "due_date": "With Application", "remarks": ""},
        {"type": "Permitted Transfer Processing Fee", "amount": "$5,500", "due_date": "When submitting request", "remarks": ""},
        {"type": "Re-licensing Application Fee", "amount": "$85,000", "due_date": "With Application", "remarks": ""},
        {"type": "Lender Comfort Letter Processing Fee", "amount": "$3,500 (letter) / $1,500 (assignment)", "due_date": "Before issuance", "remarks": ""},
        {"type": "Public Offering/Private Placement Fee", "amount": "$5,000", "due_date": "When submitting request", "remarks": "Plus additional costs"},
        {"type": "Actual Damages Under Special Circumstances", "amount": "Varies", "due_date": "On demand", "remarks": "For early termination"},
        {"type": "Liquidated Damages — Pre-opening", "amount": "System Average Monthly Royalty × 60", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages — Post-opening (<2 yr)", "amount": "Greater of Hotel or System avg × 60", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages — Post-opening (>2 yr, before final 60 mo)", "amount": "Hotel Average Monthly Royalty × 60", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages — Final 60 months", "amount": "Hotel Average Monthly Royalty × remaining months", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Service Charges for Overdue Payments", "amount": "1.5%/month or legal max", "due_date": "On demand", "remarks": ""},
        {"type": "Identity/Sales/Distribution Non-Compliance", "amount": "$500/instance", "due_date": "On demand", "remarks": ""},
        {"type": "FastPay Non-compliance", "amount": "$500–$3,000/violation", "due_date": "On demand", "remarks": "Escalating"},
        {"type": "Restaurant Brand Annual Fee", "amount": "$14,500", "due_date": "Annually by Jan 15", "remarks": "Per brand"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due_date": "As agreed", "remarks": "If using HSM"}
      ],
      "table_notes": [
        "Note 1: GRR = Gross Rooms Revenue per USALI. Includes redemption points, mandatory guest fees, no-show revenue, etc. Excludes taxes.",
        "Note 2: Monthly Program Fee may increase up to current rate +1% over term. Funds reservations, directories, marketing, QA, tech, admin.",
        "Note 3: QA program includes Plans/Designs Late Fee, Brand Non-Compliance, PIP/Renovation Failure, Stay Score, SQIP. More than one fee may apply.",
        "Note 4: SQIP total fees will not exceed $50,000 over 6-month period plus third-party vendor costs.",
        "Note 5: Sales/distribution programs may be added/removed/modified. Some use automatic enrollment with opt-out.",
        "Note 6: Must participate in all required guest frequency programs including Hilton Honors.",
        "Note 7: Online group booking platform terms subject to change.",
        "Note 8: Hotel's Average Monthly Royalty Fees = total royalty for 24 months before termination / 24. System's Average = average per room × approved rooms. Excludes financial accommodations and business interruptions."
      ]
