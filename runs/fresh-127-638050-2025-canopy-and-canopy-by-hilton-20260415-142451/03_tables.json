        {"type": "Hilton Core Sales Skills Training", "amount": "Up to $600/attendee", "due_date": "Before attendance", "remarks": "Within 90 days of start"},
        {"type": "Other Training Programs", "amount": "Up to $5,000/program/attendee", "due_date": "Before attendance", "remarks": "Some required, some optional"},
        {"type": "Travel Clubs (AAA/CAA)", "amount": "$0.30/available room + 10% commission", "due_date": "Annually on DS/TAC invoice", "remarks": ""},
        {"type": "Hilton Advance Program", "amount": "1.35% of eligible Digital Direct Revenue, max $30/stay", "due_date": "Within 15 days or ACH 12th day", "remarks": "Lower-funnel marketing"},
        {"type": "Group Preferred Partnership", "amount": "Up to $1.80/consumed room night + commission", "due_date": "Within 15 days or ACH 12th day", "remarks": "Optional. May increase to $2.50"},
