    {
      "table_id": "T5-1",
      "item": 5,
      "title": "Initial Franchise Fees",
      "source_pages": [16],
      "columns": ["Scenario", "Amount"],
      "rows": [
        {"scenario": "First outlet in county", "amount": "$20,000"},
        {"scenario": "Additional outlet in same county", "amount": "$5,000"},
        {"scenario": "Additional outlet in new county (signed before 3/10/2022)", "amount": "$10,000"},
        {"scenario": "Additional outlet in new county (signed 3/11/2022 to 3/11/2025)", "amount": "$15,000"},
        {"scenario": "Veteran discount", "amount": "-$5,000"},
        {"scenario": "ADRSA Territory Fee", "amount": "$100"}
      ],
      "table_notes": [
        "All fees non-refundable, due at signing.",
        "Franchisor may cancel before training completion without liability.",
        "ADRSA Territory Fee is separate; each ADRSA outlet requires separate FA and initial franchise fee."
      ]
    },
    {
      "table_id": "T6-1",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [16, 17, 18, 19],
      "columns": ["Fee Type", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee_type": "Royalty", "amount": "$150 per Transaction Side", "due_date": "15th of following month", "remarks": "CPI-adjusted. Must send transaction report."},
        {"fee_type": "Marketing and Promotion Fees", "amount": "$250/month", "due_date": "15th of following month", "remarks": "CPI-adjusted. Monthly."},
        {"fee_type": "Agent Website Fee", "amount": "$16.96 per agent/month", "due_date": "15th of following month", "remarks": "Only if using recommended website provider. Otherwise Roster Only + IDX charges."},
        {"fee_type": "Additional Advertising Assessment", "amount": "Variable", "due_date": "On demand", "remarks": "Requires 2/3 franchisee approval."},
        {"fee_type": "Renewal Fee", "amount": "$5,000 ($2,500 if fully compliant)", "due_date": "At renewal signing", "remarks": "CPI-adjusted."},
        {"fee_type": "Transfer Fee", "amount": "$5,000", "due_date": "10 days before transfer", "remarks": "No fee for transfer to entity solely owned by franchisee. CPI-adjusted."},
        {"fee_type": "Interest", "amount": "18% APR", "due_date": "On demand", "remarks": "From date payment originally due."},
        {"fee_type": "Costs of Collection", "amount": "Variable", "due_date": "On demand", "remarks": "In addition to late penalty and interest."},
        {"fee_type": "Optional Training/Conference Fee", "amount": "$500 to $5,000 + trainer travel", "due_date": "At training", "remarks": "CPI-adjusted."},
        {"fee_type": "Late Payment Penalty", "amount": "5% of past due", "due_date": "On demand", "remarks": "Per occurrence. In addition to interest."},
        {"fee_type": "Audit", "amount": "$3,000 to $7,500 + interest on underpayment", "due_date": "On demand", "remarks": "Only if understated revenue >=5% or audit >8 hours."},
        {"fee_type": "Interim Manager", "amount": "$750/day + travel/lodging/living", "due_date": "Weekly", "remarks": "CPI-adjusted."},
        {"fee_type": "Reimbursement for Curing Defaults", "amount": "Variable", "due_date": "On demand", "remarks": "If franchisor cures default on your behalf."},
        {"fee_type": "Proposed Supplier Review Fee", "amount": "$250", "due_date": "At submission", "remarks": "Non-refundable. CPI-adjusted."},
        {"fee_type": "Attorneys Fees and Costs", "amount": "Variable", "due_date": "On demand", "remarks": "If franchisor uses attorney to enforce."},
        {"fee_type": "Recovery of Lost Royalties", "amount": "150%-300% of 3-year aggregate royalty", "due_date": "On demand", "remarks": "Only upon termination for material breach. Minimum $20,000 if <1 year. Tiered: <1yr=300%, 1-2yr=200%, 2-3yr=150%."},
        {"fee_type": "Indemnification", "amount": "Variable", "due_date": "On demand", "remarks": "For unauthorized IP use, noncompete breach, or tort/negligence."}
      ],
      "table_notes": [
        "Note 1: Fees must be paid in full at indicated time. Credit check required.",
        "Note 2: 18% APR interest on late payments (or lower state-mandated rate). Court costs, investigator fees, expert witness fees, attorney fees recoverable.",
        "Note 3: CPI-adjusted upward based on Consumer Price Index for All Urban Consumers.",
        "Note 4: Additional advertising assessment requires 2/3 affirmative vote of all affected franchisees.",
        "Note 5: Franchisor has right to continually inspect outlet."
      ]
    },
