      ],
      "total_low": "$58,500",
      "total_high": "$206,500",
      "table_notes": [
        "Note 1: Initial fee varies $5,000-$20,000 based on county and prior franchise history.",
        "Note 2: Grand opening minimum $1,000 in first 6 months.",
        "Note 3: Training typically 3 days in Hershey, PA.",
        "Note 4: Many franchisees convert existing offices. Outlet size 1,500-3,000 sq ft.",
        "Note 5: Build-out estimates based on basic IVRE office design.",
        "Note 6: Signage varies per lease space and local regulations.",
        "Note 7: Accounttech POS at $2.60/agent/month + $10/admin/month. RingCentral $73-$163/month. Office 365 ~$240/year.",
        "Note 8: Insurance: $1M GL, auto $100K/$300K/$100K, workers comp.",
        "Note 9: Includes security deposits, utility deposits, business licenses.",
        "Note 10: 3-month operating reserve based on founder's 18 years experience.",
        "Note 11: Non-refundable except possible supplier refunds if not opened. Franchisor does not finance."
      ]
