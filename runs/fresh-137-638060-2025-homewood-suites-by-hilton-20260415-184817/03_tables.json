        {"type": "Hilton Advance Program", "amount": "1.35% of Digital Direct Revenue (max $30/stay)", "due_date": "Monthly", "remarks": "See Note 1"},
        {"type": "Group Preferred Partnership", "amount": "Up to $1.80/consumed room night + commission", "due_date": "Monthly", "remarks": "Optional"},
        {"type": "Hilton Honors", "amount": "2.5% of eligible folio", "due_date": "10 days after billing", "remarks": "Mandatory; waived for on-property enrollments"},
        {"type": "Hilton For Business", "amount": "Up to 3% GRR per eligible stay", "due_date": "As incurred", "remarks": "Optional; auto-enrolled with opt-out"},
        {"type": "Centralized Payment Programs", "amount": "$0.18–$5.93 per transaction/stay", "due_date": "Monthly", "remarks": "Multiple sub-programs"},
        {"type": "Change of Ownership Application Fee", "amount": "$200,000", "due_date": "With Application", "remarks": "For non-Permitted Transfers"},
        {"type": "Permitted Transfer Processing Fee", "amount": "$5,500", "due_date": "With request", "remarks": "For qualifying Permitted Transfers"},
        {"type": "Re-licensing Application Fee", "amount": "$100,000", "due_date": "With Application", "remarks": "To existing franchisee"},
        {"type": "Lender Comfort Letter Fee", "amount": "$3,500 (letter) / $1,500 (assignment)", "due_date": "Before issuance", "remarks": "If requested and qualified"},
        {"type": "Liquidated Damages – Pre-Opening", "amount": "System's Average Monthly Royalty × 60", "due_date": "On demand", "remarks": "If terminated before opening"},
        {"type": "Liquidated Damages – Post-Opening (first 2 years)", "amount": "Greater of Hotel's or System's Avg Monthly Royalty × 60", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Liquidated Damages – Post-Opening (after 2 years)", "amount": "Hotel's Avg Monthly Royalty × 60", "due_date": "On demand", "remarks": "Until last 60 months"},
        {"type": "Liquidated Damages – Last 60 months", "amount": "Hotel's Avg Monthly Royalty × remaining months", "due_date": "On demand", "remarks": "See Note 8"},
        {"type": "Service Charges for Overdue Payments", "amount": "1.5%/month or legal max", "due_date": "On demand", "remarks": "On any late payment"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due_date": "As agreed", "remarks": "If buying from HSM"}
      ],
      "table_notes": [
        "Note 1: GRR = Gross Rooms Revenue per USALI. Includes room rental, loyalty point redemptions, breakfast bundled with room rate, mandatory guest fees, no-show revenue. Excludes taxes.",
        "Note 2: Monthly Program Fee may increase up to +1% GRR over term. Covers reservation systems, directories, marketing, quality assurance, technology, admin.",
        "Note 5: Sales/distribution programs may be added, removed, or modified at any time. Auto-enrollment with opt-out for some.",
        "Note 6: Must participate in Hilton Honors. Programs subject to change. Hotel reimburses for free night redemptions per Hilton Honors program terms.",
        "Note 8: Hotel's Average Monthly Royalty = trailing 24-month royalty fees / 24 (or pro-rated if open < 24 months). System's Average = average per-room royalty across all US System Hotels × approved rooms."
      ]
