      "table_id": "T01",
      "item": "Item 5",
      "title": "Initial Fees",
      "source_pages": [22, 23],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Franchise Application Fee – New Dev/Conversion", "amount": "$100,000 + $400/room over 150", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee – Change of Ownership", "amount": "$200,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee – Re-licensing", "amount": "$100,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "PIP Fee", "amount": "$10,000", "due_date": "Before PIP inspection", "remarks": "For Conversion, COO, or Re-licensing"},
        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due_date": "With written request", "remarks": "See Note 2"},
        {"type": "OnQ Computer System Fees", "amount": "$28,296–$118,424", "due_date": "As agreed", "remarks": "See Note 3"},
        {"type": "Other Initial Start Up Fees", "amount": "$5,100", "due_date": "On or before opening", "remarks": "GRO, Digital Floor Plan, Opening Transition Tool"},
        {"type": "Training Program Fees", "amount": "$5,000–$17,500", "due_date": "As agreed", "remarks": "See Item 11"},
        {"type": "Opening Process Services Fee", "amount": "$6,000", "due_date": "Before opening", "remarks": "Pre-opening services"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due_date": "As agreed", "remarks": "If franchisor furnishes/supplies at request"},
        {"type": "Miscellaneous Services", "amount": "As agreed", "due_date": "As agreed", "remarks": "Additional optional/mandatory services"}
      ],
      "table_notes": [
        "Note 1: Application fee refundable minus $7,500 processing fee if withdrawn/denied. In 2024, actual fees ranged $0–$100K (new), $25K–$200K (COO), $50K–$100K (re-licensing). Fee modified in 25 instances in 2024.",
        "Note 2: New Dev must start construction within 15 months. 30-day automatic rolling extensions for New Dev/Conversion without fee.",
        "Note 3: Includes OnQ hardware, software, installation. GRO setup ~$3,400. Digital Floor Plan $1,500. Opening Transition Tool up to $1,000.",
        "Note 4: HSM procurement fee 4%–10% plus product cost, freight, taxes. Late payment interest 18.5%/year compounded daily."
      ]
    },
