      "item": 5,
      "title": "Initial Franchise Fee Schedule",
      "source_pages": [15, 16],
      "columns": ["Experience or Location", "Amount", "Remarks"],
      "rows": [
        {"experience_or_location": "Standard initial franchise fee", "amount": "$25,000", "remarks": "Standard fee for new franchisees"},
        {"experience_or_location": "Existing WZ franchisee adding start-up", "amount": "$1,000", "remarks": "40%+ owner of existing WZ franchise, must own 40%+ of new entity"},
        {"experience_or_location": "Converting existing wireless retail store", "amount": "$1,000", "remarks": "One-time at initial conversion only; subsequent stores at standard rates"}
      ],
      "table_notes": [
        "Vet*Fran discount: 50% off standard fee for honorably discharged veterans (51%+ owner). Cannot combine with other discounts. Limited to 1 per individual/entity.",
        "Fee due in full at signing. Fully earned and non-refundable except possible partial refund if site not found within 180 days and franchisor terminates.",
        "In 2024, franchise fees ranged from $0 to $1,000."
      ]
    },
    {
      "table_id": "T02_item6_other_fees",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [17, 18, 19, 20, 21, 22, 23, 24],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Royalties", "amount": "9%-22% of Gross Profit (sliding scale)", "due_date": "Deducted from Commissions/Residuals; deficiency by 10th of month", "remarks": "22% on first $5,000 GP/month, decreasing to 9% on GP above $100,000/month. Incentive programs may reduce rates."},
        {"type": "New Program Fees", "amount": "Amount determined by franchisor", "due_date": "As determined", "remarks": "For participation in programs, marketing, products, services, revenue opportunities"},
        {"type": "Foundation Contribution", "amount": "$0.25 per activation/upgrade transaction", "due_date": "At customer sale", "remarks": "Mandatory participation in philanthropic programs supporting the Foundation"},
        {"type": "Audits", "amount": "Cost of audit + underpayment + interest", "due_date": "Within 10 days of billing", "remarks": "If understate royalties by 2%+ or fail to produce records"},
        {"type": "Interest", "amount": "1.5% per month", "due_date": "On demand", "remarks": "On outstanding balance unless limited by law"},
        {"type": "Sales/Use/Gross Receipts/Excise Tax", "amount": "Amount imposed by taxing authority", "due_date": "On demand", "remarks": "Franchisee bears all applicable taxes on payments to franchisor"},
        {"type": "Bank Charges/Admin/Credit Card Fees", "amount": "Amount of bank/CC charge + admin fee up to $50/month or per transaction", "due_date": "On demand", "remarks": "For unsuccessful EFT, closed accounts, returned payments, credit card payments"},
        {"type": "Renewal Fee", "amount": "$1,000", "due_date": "At signing of new agreement (before expiration)", "remarks": ""},
        {"type": "Holdover Fee", "amount": "$500/month", "due_date": "Upon demand", "remarks": "If operating after agreement expires; in addition to all other fees; not credited against renewal fee"},
        {"type": "Training No-Show Fee", "amount": "$500-$2,000 per no-show", "due_date": "Upon billing", "remarks": "For registered training/meetings not attended"},
        {"type": "Transfer Fee", "amount": "Up to $5,000 (currently $1,000)", "due_date": "On or before transfer date", "remarks": "50% discount for multi-store acquisitions"},
        {"type": "Software License/POS License", "amount": "$103/month + ~10% vendor program fee", "due_date": "Upon billing", "remarks": "Includes up to 6 POS licenses; collected on behalf of third-party vendor"},
        {"type": "Signs/Fixtures/Kiosks/Displays", "amount": "$65,000-$170,000+", "due_date": "As incurred", "remarks": "Depends on store size, scope, market"},
        {"type": "Computer/WSS Tech & Support", "amount": "$7,000-$9,000 + $100/month", "due_date": "Upon billing", "remarks": "Dependent on store configuration and POS installation options"},
        {"type": "Digital Video and Radio", "amount": "$20-$40/month", "due_date": "Upon billing", "remarks": "Collected on behalf of third-party vendor"},
        {"type": "Retail Direct Ship", "amount": "$10/transaction (can increase $10/year)", "due_date": "As incurred", "remarks": "For transactions closed by remote call center on franchisee's behalf"},
        {"type": "Automated Messaging Platform", "amount": "$30-$50/month", "due_date": "Upon billing", "remarks": "Collected on behalf of third-party vendor"},
        {"type": "ReBiz (Traffic Counter)", "amount": "$1,600 install + $180/month", "due_date": "Upon billing", "remarks": "Mandatory traffic counting/monitoring/reporting system"},
        {"type": "Additional Training", "amount": "$1,000-$10,000", "due_date": "Upon billing", "remarks": "Plus travel/lodging/meals reimbursement for franchisor reps"},
        {"type": "Ongoing Product Inventory", "amount": "$80,000-$225,000/month", "due_date": "Payment in advance unless 65-day terms offered", "remarks": "Varies by sales level, demand, season, delivery schedule"},
        {"type": "Insurance Procurement Fee", "amount": "Cost of coverage + third-party expenses", "due_date": "Upon invoice", "remarks": "If franchisee fails to obtain required insurance, franchisor may do so at franchisee's expense"},
        {"type": "Customer Service Charges", "amount": "Cost to resolve service issues", "due_date": "Upon invoice", "remarks": "If franchisor resolves complaints franchisee does not"},
        {"type": "Step-in Rights Exercise", "amount": "Franchisor's costs + indemnification", "due_date": "As incurred", "remarks": "When franchisor operates store under jeopardy or default"},
        {"type": "Reserve for Charge-Backs", "amount": "Based on historical data (6 months post-termination)", "due_date": "Upon termination/expiration", "remarks": "Fund for Provider charge-backs after agreement ends"},
        {"type": "Provider Allowances", "amount": "Amount of Provider charge-backs", "due_date": "As incurred", "remarks": "Reimburse franchisor for Provider charge-backs to previously granted allowances"},
        {"type": "IP Infringement Liquidated Damages", "amount": "$1,000/day", "due_date": "As incurred", "remarks": "For continued use of IP after termination/expiration"},
        {"type": "Signs/Kiosks/Displays/Property Removal", "amount": "Franchisor's costs", "due_date": "As incurred", "remarks": "If franchisee fails to return property after termination"},
        {"type": "Marketing Development Funds Termination", "amount": "Repay MDF received + pro rata for activation shortfall", "due_date": "Upon termination or activation failure", "remarks": "MDF from Provider; subject to Provider conditions"},
        {"type": "Non-Competition/Non-Disclosure Damages", "amount": "$100,000 per violation + attorneys' fees", "due_date": "As incurred", "remarks": "Liquidated damages, not penalty"},
        {"type": "Noncompliance with Provider Compliance Agreement", "amount": "$500/subscriber + up to $2,000/day + up to $1,000/location/day", "due_date": "As incurred", "remarks": "For breach of Personal Information section"},
        {"type": "Indemnification", "amount": "Amount of loss/damages + costs", "due_date": "As incurred", "remarks": "Must indemnify franchisor from claims arising from store operation"},
        {"type": "Attorneys' Fees", "amount": "Varies", "due_date": "As incurred", "remarks": "If franchisor successful in any lawsuit"}
      ],
      "table_notes": [
        "Note 1: All fees non-refundable, uniformly imposed except as noted. Deducted from Commissions/Residuals first; deficiency auto-drafted from bank.",
        "Note 2: Gross Profit = Gross Revenue - Allowable Cost. Gross Revenue includes device sales, Commissions, Residuals, trade-ins, customer fees, other Provider payments. Excludes certain incentives, MDF, co-op funds.",
        "Note 3: Commissions and Residuals paid ~1st business day of 2nd month following month earned.",
        "Note 4: Commission/Residual payments per published Commission Schedule; may be charged back on store closure, transfer, or Provider policy non-compliance.",
        "Note 5: Incentive program terms announced at beginning of each period, subject to change, apply uniformly to qualifying franchisees.",
        "Note 6: Renewal fee due at time of renewal.",
        "Note 7: Transfer fee may be reduced 50% for multi-store acquisitions.",
        "Note 8: Additional training at franchisor's discretion; may be delivered in-person, online, or electronic.",
        "Note 9: Provider compliance fees: up to $2,000/day and $1,000/location/day for each day/location of continued non-compliance."
      ]
    },
