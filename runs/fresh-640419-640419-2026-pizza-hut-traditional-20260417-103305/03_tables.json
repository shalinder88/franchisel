        {"fee_type": "Initial Franchise Fee", "amount": "$25,000 per System Restaurant", "notes": "Lump sum, non-refundable. May increase with CPI. Waived for ACE program enrollees (closed)."}
      ],
      "table_notes": []
    },
    {
      "table_id": "item6_other_fees",
      "item": "Item 6",
      "title": "Other Fees",
      "source_pages": [19, 20, 21, 22, 23, 24],
      "columns": ["fee_type", "amount", "due_date", "remarks"],
      "rows": [
        {"fee_type": "Monthly Service Fee", "amount": "6.0% of Gross Sales (6.5% in certain circumstances)", "due_date": "Monthly by 20th", "remarks": "Not uniformly imposed. See Note 1 re: alcoholic beverage exclusion."},
        {"fee_type": "Taxes", "amount": "As levied", "due_date": "As incurred", "remarks": "All taxes on franchisor services/goods."},
        {"fee_type": "System Advertising Fund Contribution", "amount": "4.75% of Gross Sales", "due_date": "Same as Monthly Service Fee", "remarks": "Credited against IPHFHA dues."},
        {"fee_type": "IPHFHA Dues", "amount": "4.75% of Gross Sales", "due_date": "Per IPHFHA", "remarks": "Credited to System Ad Fund."},
        {"fee_type": "Digital Innovation Fee", "amount": "$0.41 per digital transaction", "due_date": "Same as Monthly Service Fee", "remarks": "To PHLLC or affiliates (Digico). See Notes 3, 4."},
        {"fee_type": "Restaurant Technology Fee", "amount": "$2,950 per year", "due_date": "12 monthly bills", "remarks": "To PHLLC or PH Connect. Max 12%/yr increase. See Notes 3, 4."},
        {"fee_type": "Help Desk High-Use Fee", "amount": "$12/call, $7/other event beyond 52/yr", "due_date": "When applicable", "remarks": "Excludes system-wide issues, new openings. May increase 50%."},
        {"fee_type": "Dragontail KMX Fee", "amount": "$240 install + $75/mo/restaurant", "due_date": "Monthly with tech fee", "remarks": "Required for DaaS. Suspended Q1 2026 per Hut Forward."},
        {"fee_type": "Initial Training Costs", "amount": "$500/person/week additional trainees", "due_date": "Before training", "remarks": "First QO included in franchise fee."},
        {"fee_type": "On-Going Training", "amount": "$50-$150/day + travel/lodging", "due_date": "As incurred", "remarks": "May increase 50%."},
        {"fee_type": "Inspection/Testing Costs", "amount": "Actual costs", "due_date": "When requested", "remarks": "For proposed supplier approval."},
        {"fee_type": "Audit", "amount": "Actual audit expenses", "due_date": "5 business days after billing", "remarks": "Pay deficiency + finance charge if ≥2%."},
        {"fee_type": "Late Charges", "amount": "1.5%/month", "due_date": "As incurred", "remarks": "May increase to max legal rate."},
        {"fee_type": "Unauthorized Closure", "amount": "24x avg monthly royalty of prior year", "due_date": "Upon closure", "remarks": "If open <1 year: 24x highest monthly royalty."},
        {"fee_type": "Relocation", "amount": "Varies", "due_date": "When replacement opens", "remarks": "New franchise fee if not open within 12 months."},
        {"fee_type": "Transfer Fee", "amount": "$2,500 + $250/restaurant", "due_date": "Upon request", "remarks": "Plus outside counsel fees."},
        {"fee_type": "Renewal Fee", "amount": "$12,500/restaurant", "due_date": "Upon execution", "remarks": "May increase to $25,000."},
        {"fee_type": "Interim Operation Fee", "amount": "Greater of 2x salary or 10% monthly Gross Sales + expenses", "due_date": "As incurred", "remarks": "On death/disability without QO."},
        {"fee_type": "Advances", "amount": "Varies", "due_date": "When requested", "remarks": "Not obligated to make advances."},
        {"fee_type": "Indemnification", "amount": "Varies", "due_date": "When requested", "remarks": "Broad scope. See FA Section 14.01."},
        {"fee_type": "Attorneys'/Experts' Fees", "amount": "Varies", "due_date": "Upon demand", "remarks": "Loser-pays."},
        {"fee_type": "Termination Damages", "amount": "Varies", "due_date": "Upon demand", "remarks": "Lost profits, lost opportunities."},
        {"fee_type": "De-identification Costs", "amount": "Actual cost", "due_date": "As incurred", "remarks": "If you fail to de-identify."},
        {"fee_type": "Third Party Dinova Program", "amount": "9.5% on orders >$20", "due_date": "60 days from invoice", "remarks": "Opt-out available."},
        {"fee_type": "EPR Fees", "amount": "Actual fees + costs", "due_date": "Upon demand", "remarks": "Extended producer liability."}
      ],
      "table_notes": [
        "Note 1: If state law excludes alcoholic beverage sales from royalty base, PHLLC estimates excluded revenues and sets effective royalty rate.",
        "Note 2: Gross Sales = all revenues from any source, less good-faith customer credits/allowances and sales taxes properly remitted.",
        "Note 3: Tech Framework Agreement (Dec 27, 2022) affects SUS/FMS and QuikOrder agreements including fee increases for Restaurant Technology Fee, Digital Innovation Fee, and Help Desk High-Use Fee.",
        "Note 4: Digital Innovation Fee and Restaurant Technology Fee may increase (i) consistent with CPI or (ii) as approved by Technology Governance Committee. Digital Innovation Fee last increased Jan 1, 2024.",
        "Note 5: You must pay outside counsel fees for proposed transfers (FA Section 18.11).",
        "Note 6: Interim Operation Fee is in addition to Monthly Service Fee.",
        "Note 7: You indemnify PHLLC from losses arising from your FA execution, operations, employment practices, third-party claims (FA Section 14.01, Appendix A).",
        "Note 8: Loser-pays attorneys' fees in litigation (FA Section 36.07). You also pay PHLLC's counsel fees for FA amendments (FA Section 30.02).",
        "Note 9: On termination for default, you must pay all losses including reasonable attorneys' fees, lost profits, lost opportunities (FA Section 24.01).",
        "All fees nonrefundable. PHLLC can apply payments to oldest obligation."
      ]
    },
