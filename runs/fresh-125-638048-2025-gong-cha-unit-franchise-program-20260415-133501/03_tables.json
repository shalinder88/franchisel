      ]
    },
    {
      "table_id": "T02_item6_other_fees",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [20, 21, 22, 23, 24, 25, 26],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Type of Fee": "Royalty Fee", "Amount": "6% of weekly Net Sales", "Due Date": "3rd Business Day of each Week", "Remarks": "See Note 1"},
        {"Type of Fee": "Brand Marketing Fee", "Amount": "1% of weekly Net Sales (can increase to 2%)", "Due Date": "3rd Business Day of each Week", "Remarks": "Deposited to Brand Marketing Fund. See Notes 1 and 2"},
        {"Type of Fee": "Regional Marketing Fee", "Amount": "Up to 2% of Net Sales (can exceed by coop vote)", "Due Date": "As directed", "Remarks": "If Cooperative Ad Fund established. See Note 2"},
        {"Type of Fee": "Additional Training Fees", "Amount": "See Note 3", "Due Date": "Upon demand", "Remarks": "Currently $2,000/person"},
        {"Type of Fee": "Additional Opening or On-site Training", "Amount": "$1,000 to $3,000 per person (per diem + expenses)", "Due Date": "Upon demand", "Remarks": "Only if requested and agreed"},
        {"Type of Fee": "Supplies and Inventory Fees", "Amount": "Actual costs", "Due Date": "Upon demand", "Remarks": "From franchisor/GCPS. See Note 5 re tariffs"},
        {"Type of Fee": "Technology System Fees", "Amount": "$313/year beverage maker SaaS + $295/month POS SaaS", "Due Date": "Upon demand", "Remarks": "Can increase 25% over FA term"},
        {"Type of Fee": "Prohibited Product or Service Fee", "Amount": "$250/day", "Due Date": "Upon demand", "Remarks": "Can increase 25% over FA term"},
        {"Type of Fee": "Relocation Fee", "Amount": "50% of IFF + costs", "Due Date": "Upon demand", "Remarks": "If you relocate"},
        {"Type of Fee": "Renewal Fee", "Amount": "50% of then-current standard IFF", "Due Date": "Before FA expires", "Remarks": "If you renew"},
        {"Type of Fee": "Transfer Fee", "Amount": "50% of then-current standard IFF; ADA adds $5,000", "Due Date": "Before transfer", "Remarks": "If you transfer"},
        {"Type of Fee": "Securities Offering Review Fee", "Amount": "Actual costs (legal/accounting)", "Due Date": "Upon demand", "Remarks": "If you seek to offer securities"},
        {"Type of Fee": "Bank Charges and Fees", "Amount": "Assessed charges", "Due Date": "Upon demand", "Remarks": "Failed EFT payments. See Note 6"},
        {"Type of Fee": "Late Payment Administrative Fee", "Amount": "5% of overdue amount", "Due Date": "As incurred", "Remarks": "Subject to state law"},
        {"Type of Fee": "Interest", "Amount": "Lesser of 1.5%/month or highest rate allowed by law", "Due Date": "As incurred", "Remarks": "Subject to state law"},
        {"Type of Fee": "Audit", "Amount": "Cost of audit (travel, lodging, wages, accounting, legal)", "Due Date": "Upon demand", "Remarks": "Only if understatement ≥3% of Net Sales"},
        {"Type of Fee": "Designated Accountant Fee", "Amount": "Cost of designated accountant", "Due Date": "Monthly", "Remarks": "If franchisor requires coordinated services"},
        {"Type of Fee": "Quarterly Health and Safety Audits", "Amount": "$200-$400 per audit; $500 1st revisit fail; $11,000 2nd revisit fail", "Due Date": "As incurred", "Remarks": "Up to 4 regular audits/year"},
        {"Type of Fee": "Cost to Correct Post-Inspection Deficiencies", "Amount": "Franchisor's costs", "Due Date": "As incurred", "Remarks": "If you fail to correct in reasonable time"},
        {"Type of Fee": "Insurance", "Amount": "Franchisor's cost + admin fee", "Due Date": "Upon demand", "Remarks": "If you fail to maintain required coverage"},
        {"Type of Fee": "Customer Satisfaction Costs", "Amount": "Franchisor's costs", "Due Date": "Upon demand", "Remarks": "Resolve customer complaints on your behalf"},
        {"Type of Fee": "Indemnification", "Amount": "Actual costs", "Due Date": "As incurred", "Remarks": "Claims arising from Store"},
        {"Type of Fee": "Cost of Enforcement or Defense", "Amount": "Attorneys' fees + accounting", "Due Date": "As incurred", "Remarks": "If franchisor wins"},
        {"Type of Fee": "Taxes", "Amount": "Amount of tax", "Due Date": "Upon demand", "Remarks": "Tax on fees owed, excluding income taxes"}
      ],
      "table_notes": [
        "Note 1: Net Sales defined as all revenue from sale of all products minus customer refunds and collected sales taxes. Week = Monday through Sunday.",
        "Note 2: Total Advertising Obligation up to 4% of Net Sales in aggregate. Can exceed if coop members vote to increase. Brand Marketing Fee 1% currently, can increase to 2% on 90 days notice.",
        "Note 3: Initial training for up to 3 attendees at no additional fee. Additional training: $2,000/person. Can increase 25% over FA term.",
        "Note 4: Additional opening/on-site training per diem $1,000-$3,000/person. Can increase 25% over FA term.",
        "Note 5: Supplies sourced globally including China; tariffs may apply and will be passed through to franchisee.",
        "Note 6: EFT required. Franchisor can debit estimated fees if Net Sales not timely reported."
      ]
    },
