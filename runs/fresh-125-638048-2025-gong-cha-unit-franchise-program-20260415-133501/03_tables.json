        {"Fee Type": "Initial Supplies and Inventory", "Amount": "$25,750 to $61,800", "Refundable": "No"},
        {"Fee Type": "Grand Opening Advertising Program", "Amount": "Minimum $4,000", "Refundable": "No"},
