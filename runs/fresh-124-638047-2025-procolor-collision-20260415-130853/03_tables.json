    {
      "table_id": "T02",
      "source_item": "Item 6",
      "source_pages": [16, 17, 18],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        ["Monthly Franchise Fee", "Greater of $2,000/mo or 3% Gross Sales (new); Base + Growth for conversions (Note 1)", "15th of each month", "See Note 1 for conversion structure"],
        ["Marketing Fund Contribution", "0.75% Gross Sales (Note 2)", "15th of each month", "Max 1% with majority approval"],
        ["Training Fees", "$200-$300/day/trainer + travel", "Upon demand", "See Note 3"],
        ["Convention Fee", "$1,000-$1,500/person", "Upon demand", "2 meetings/year; must pay regardless of attendance (Note 4)"],
        ["Alternative Supplier Payments", "Up to 2.6% Gross Sales (Notes 5, 6)", "15th of month", "1.6% for existing paint vendor + 1% for parts noncompliance"],
        ["Promotional Inventory", "Up to $50/month", "Upon demand", "Auto-shipped items"],
        ["Insurers Account", "Varies (Note 7)", "Per agreement", "Volume rebates typically 1-5%"],
        ["National Warranty Program", "Cost of warranty service (Note 8)", "15th of following month", "Must participate; absorb <$100"],
        ["Email Fees", "$6.30-$9.18/month/account", "Monthly", "Min 1 account required"],
        ["Renewal Fee", "$5,000", "Before renewal", ""],
        ["Transfer Fee", "$10,000", "Before transfer", "Payable by you or transferee"],
        ["Insurance", "Varies", "Upon demand", "If franchisor obtains for you"],
        ["Audit", "Cost of audit", "Upon demand", "Only if understatement ≥2%"],
        ["Indemnification", "Varies", "As incurred", ""],
        ["Cost of Enforcement/Defense", "All costs incl. attorneys' fees", "As incurred", ""],
        ["Default Reimbursement", "All costs", "Upon demand", ""],
        ["Interest on Late Payments", "Lesser of 1.5%/month or legal max", "As incurred", ""],
        ["Late Gross Sales Report/Non-Access Fee", "$200 (subject to 25% annual increase)", "On demand", ""]
      ],
      "table_notes": [
        "Note 1: Conversion structure — Monthly Base Fee = greater of $2,000 or 1.5% of Monthly Base Volume; Monthly Growth Royalty = 3% of excess over Monthly Base Volume. Monthly Base Volume = Annual Base Volume / 12, where Annual Base Volume = average annual Gross Sales for 3 years before signing. Franchisor may adjust within 90 days of fiscal year end.",
        "Note 2: Marketing Fund may increase to max 1% with majority approval of all US ProColor locations.",
        "Note 3: Mandatory training; $200-$300/day/trainer + reimbursement of third-party costs.",
        "Note 4: Must pay convention fee regardless of attendance.",
        "Note 5: Existing paint vendor agreement — 1.6% Gross Sales administrative fee during agreement term.",
        "Note 6: Parts sourcing — must purchase from designated suppliers at ≥85% participation. Noncompliance → compliance plan → if still noncompliant after 90 days → 1% Gross Sales fee.",
        "Note 7: Insurers Account — volume rebates/consideration typically 1-5% of insurance payments but can be greater. $15,000 retained as deposit upon termination for 18 months.",
        "Note 8: National Warranty Program — must honor all warranties. Absorb <$100 warranty costs. Invoice franchisor for >$100. Estimate must be pre-approved."
      ],
      "provenance": "Item 6, pages 16-21 (PDF pages 16-21)"
    },
