        {"type": "Late Payment", "amount": "1.5%/month or max legal rate", "due_date": "On demand", "remarks": "On any overdue payment"},
        {"type": "COO Application Fee", "amount": "$150,000", "due_date": "With Application", "remarks": "For transfers not qualifying as Permitted"},
        {"type": "Restaurant Brands Annual Fee", "amount": "$14,500 ($19,500 Junction)", "due_date": "Annually by Jan 15", "remarks": "Per brand selected"}
      ],
      "table_notes": [
        "GRR = Gross Rooms Revenue (includes loyalty redemptions, mandatory guest fees, no-show revenue, less rebates/overcharges, excl. taxes).",
