      "item": 5,
      "title": "Initial Fees",
      "source_pages": [23, 24, 25, 26, 27],
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Franchise Application Fee — New Dev/Conversion", "amount": "$85,000 + $400/room over 250", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee — Change of Ownership", "amount": "$150,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "Franchise Application Fee — Re-licensing", "amount": "$85,000", "due_date": "With Application", "remarks": "See Note 1"},
        {"type": "PIP Fee", "amount": "$10,000", "due_date": "Before PIP inspection", "remarks": "For Conversion/COO/Re-licensing"},
        {"type": "Construction/Renovation Extension Fee", "amount": "$10,000", "due_date": "With written request", "remarks": "See Note 2"},
        {"type": "OnQ Computer System — Hardware/Software/Installation", "amount": "$103,500 to $310,800", "due_date": "As agreed", "remarks": "See Note 3"},
        {"type": "OnQ FBPP Fee (initial)", "amount": "0.35%–0.45% GRR (REIT), 0.45%–0.75% GRR (non-REIT)", "due_date": "Monthly by 15th", "remarks": "See Note 3"},
        {"type": "Other Initial Start Up Fees", "amount": "$6,500", "due_date": "Before opening", "remarks": "GRO, Digital Floor Plan, Opening Transition Tool"},
        {"type": "Eforea Spa Initial Fee", "amount": "$25,000", "due_date": "When signing Spa Amendment", "remarks": "See Note 4"},
        {"type": "Restaurant Brand Initial Fee", "amount": "$47,500 ($95,000 for Junction)", "due_date": "When signing Amendment", "remarks": "Optional; per brand selected"},
        {"type": "Training Program Fees", "amount": "$5,000 to $20,000", "due_date": "As agreed", "remarks": "Plus wages/travel/lodging of attendees"},
        {"type": "Opening Process Services Fee", "amount": "$20,000", "due_date": "Before opening", "remarks": "Pre-opening services"},
        {"type": "RMCC Pre-Opening Support", "amount": "$4,059 to $8,880", "due_date": "Within 10 days of billing", "remarks": "Required if expedited opening ≤150 days"},
        {"type": "Procurement and Services Fees", "amount": "4%–10% of project cost", "due_date": "As agreed", "remarks": "If franchisor/affiliates furnish/equip hotel"}
      ],
      "table_notes": [
        "Note 1: Refundable less $7,500 processing fee if denied/withdrawn before approval. In 2024: $75K-$85K (new dev), $0-$150K (COO), $0-$85K (re-licensing).",
        "Note 2: Auto 30-day rolling extensions for new dev/conversion unless 60-day notice to stop.",
        "Note 3: FBPP covers hardware, software, maintenance, support. REIT rate lower but excludes hardware.",
        "Note 4: Spa fee nonrefundable. Eforea is recommended but not required.",
        "Note 5: Restaurant Brands optional. Fee per brand selected.",
        "Note 6: HSM procurement fee 4%–10% plus product cost, freight, taxes."
      ]
    },
