    {
      "id": "T03_item6_other_fees",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [11, 12, 13, 14, 15, 16],
      "columns": ["Fee Type", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Fee Type": "Royalty Fee", "Amount": "6% of monthly Gross Sales", "Due Date": "10th of each month", "Remarks": "See Note 1"},
        {"Fee Type": "Advertising Fund", "Amount": "Up to 4.5%, currently 2%", "Due Date": "10th of each month", "Remarks": "See Note 2 and Item 11"},
        {"Fee Type": "Cooperative Advertising Program", "Amount": "Up to 2%, currently not assessed", "Due Date": "As required by cooperative", "Remarks": "See Item 11"},
        {"Fee Type": "Additional/repeat Initial Training", "Amount": "Up to $4,000/person; currently $1,500 ($2,000 expelled re-attendee)", "Due Date": "Prior to beginning of training", "Remarks": "See Note 3"},
        {"Fee Type": "Additional Training or Assistance", "Amount": "Up to $800/person/day; currently $400 at training location, $600 + expenses at restaurant", "Due Date": "Prior to beginning of training", "Remarks": "May include refresher training"},
        {"Fee Type": "Successor Franchise", "Amount": "$10,000", "Due Date": "Upon execution of successor franchise agreement", "Remarks": ""},
        {"Fee Type": "Transfer Fee", "Amount": "$10,000, subject to state law", "Due Date": "Before completion of transfer", "Remarks": "See Note 4. No fee if transferee is controlled entity"},
        {"Fee Type": "Product and Service Purchases", "Amount": "Cost of products ordered", "Due Date": "As incurred", "Remarks": "See Note 5 and Item 8"},
        {"Fee Type": "Testing", "Amount": "Varies (depends on supplier location, testing, item)", "Due Date": "When billed", "Remarks": "For new products or new supplier proposals"},
        {"Fee Type": "Relocation", "Amount": "Currently $10,000", "Due Date": "As incurred", "Remarks": "If relocating restaurant"},
        {"Fee Type": "Computer Systems, Maintenance, Support", "Amount": "Not currently assessed", "Due Date": "As incurred", "Remarks": "See Note 6. Reserved for future"},
        {"Fee Type": "Annual Franchisee Meeting", "Amount": "Up to $2,500", "Due Date": "When billed", "Remarks": "See Note 7. Travel/living expenses separate"},
        {"Fee Type": "Regional Advisory Council", "Amount": "Council assessments", "Due Date": "When billed", "Remarks": "May vary among councils"},
        {"Fee Type": "Audit", "Amount": "Costs of inspection/audit", "Due Date": "15 days after receiving report", "Remarks": "See Note 8. Only if understatement >3% or failure to provide records"},
        {"Fee Type": "Interest", "Amount": "Lesser of 18%/year or max by law", "Due Date": "When billed", "Remarks": "On all overdue amounts"},
        {"Fee Type": "Non-Compliance", "Amount": "$500/occurrence + $500/day continuing", "Due Date": "When billed", "Remarks": "See Note 9"},
        {"Fee Type": "Unauthorized Advertising Fee", "Amount": "$1,000/occurrence", "Due Date": "When billed", "Remarks": "Unapproved advertising/marketing"},
        {"Fee Type": "Late Fee", "Amount": "10% of past due amount", "Due Date": "When billed", "Remarks": "Each late payment"},
        {"Fee Type": "Management Fee", "Amount": "$500/person/day + expenses", "Due Date": "When billed", "Remarks": "See Note 10. Death/disability/default management"},
        {"Fee Type": "Indemnification", "Amount": "Based on claims", "Due Date": "As incurred", "Remarks": "See Note 11"},
        {"Fee Type": "Liquidated Damages", "Amount": "Sum of accrued royalties for prior 24 months + taxes", "Due Date": "Within 15 days of termination", "Remarks": "See Note 12. Reduced if remaining term < 24 months"},
        {"Fee Type": "Customer Complaint Reimbursement", "Amount": "Out-of-pocket", "Due Date": "As incurred", "Remarks": "If franchisor resolves complaint for you"},
        {"Fee Type": "Insurance Reimbursement", "Amount": "Out-of-pocket", "Due Date": "As incurred", "Remarks": "If franchisor obtains insurance for you (your failure = default)"},
        {"Fee Type": "Tax Reimbursement", "Amount": "Out-of-pocket (with gross-up)", "Due Date": "As incurred", "Remarks": "See Note 13"},
        {"Fee Type": "De-identification", "Amount": "Out-of-pocket", "Due Date": "As billed", "Remarks": "See Note 14. Post-termination"},
        {"Fee Type": "Attorneys' Fees and Costs", "Amount": "Reasonable fees", "Due Date": "As incurred", "Remarks": "If franchisor is prevailing party"}
      ],
      "table_notes": [
        "All fees imposed and collected by franchisor. May vary frequency/method of payment. Royalty non-refundable; others refundable at franchisor's discretion. Fees uniformly imposed.",
        "Note 1: Gross Sales definition is broad — includes all revenue, catering/delivery charges, gift cards, business interruption insurance proceeds. Excludes sales taxes, documented refunds/credits.",
        "Note 2: Fund may pay for video/audio/written materials, e-commerce website, advertising agencies.",
        "Note 3: Initial training for 2 people at no additional cost.",
        "Note 4: Transfer fee $10,000. No fee if transferee is entity you control.",
        "Note 5: Products purchased from franchisor/affiliates — they will profit.",
        "Note 6: Computer system support not currently charged but reserved.",
        "Note 7: Annual meeting fee covers franchisor's conference costs.",
        "Note 8: Audit cost only if records not furnished, or understatement >3%.",
        "Note 9: $500 per operational deviation + $500/day continuing.",
        "Note 10: Management fee for death/disability/default/termination/abandonment.",
        "Note 11: Indemnification for unauthorized mark use, law violations, operations claims, agreement breaches.",
        "Note 12: Liquidated damages = sum of prior 24 months royalties (or remaining term months if less). Must be paid within 30 days of termination.",
        "Note 13: Tax reimbursement includes gross-up to make franchisor whole after-tax.",
        "Note 14: De-identification costs if you fail to de-identify after termination."
      ],
      "provenance": "Item 6, PDF pages 11-16"
    },
