      "id": "T02_item5_area_dev_fee",
      "item": 5,
      "title": "Area Development Fee Schedule",
      "source_pages": [11],
      "columns": ["Component", "Amount"],
      "rows": [
        {"Component": "First Restaurant", "Amount": "$40,000"},
        {"Component": "Each Additional Restaurant", "Amount": "$30,000"},
        {"Component": "Typical Range (5-20 restaurants)", "Amount": "$160,000 - $610,000"}
      ],
      "table_notes": ["Development fee equals total initial franchise fees for all committed restaurants. No additional franchise fee upon signing individual Franchise Agreements. Non-refundable."],
      "provenance": "Item 5, PDF page 11"
