      "id": "item5_initial_franchise_fee",
      "source_item": "Item 5",
      "source_pages": [32],
      "title": "Initial Franchise Fee Schedule",
      "columns": ["Store Type", "Initial Franchise Fee"],
      "rows": [
        {"store_type": "New Franchise Store - New Franchisee", "fee": "$20,000"},
        {"store_type": "New Franchise Store - Existing Franchisee", "fee": "$15,000"},
        {"store_type": "New Franchise Store - Employee", "fee": "$15,000"},
        {"store_type": "Conversion Store - New Franchisee", "fee": "$20,000"},
        {"store_type": "Conversion Store - Existing Franchisee", "fee": "$15,000"},
        {"store_type": "Conversion Store - Employee", "fee": "$15,000"},
        {"store_type": "GNC Smoothie Bar Inclusion", "fee": "$1,000"}
      ],
      "table_notes": [
        "Existing franchisee must be current and in good standing with no past-due A/R.",
        "Employee must have been full-time 12+ months or part-time 24+ months.",
        "Fee may be prorated if lease term shorter than 5-year franchise term.",
        "VetFran program: $15,000 for honorably discharged veterans."
      ]
    },
    {
      "id": "item6_fee_table",
      "source_item": "Item 6",
      "source_pages": [35, 36, 37, 38, 39, 40, 41],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"type": "Royalty", "amount": "6% of total gross sales", "due": "Monthly", "remarks": "Gross sales exclude sales tax and substantiated refunds"},
        {"type": "National Advertising", "amount": "3% of total gross sales", "due": "Monthly", "remarks": "May increase/decrease on 30 days notice"},
        {"type": "Transfer Fee (FA)", "amount": "Up to then-current initial franchise fee; $1,000 intra-family; $2,500 for <50% interest", "due": "At transfer", "remarks": "Payable when selling franchised business"},
        {"type": "Transfer Fee (ADA)", "amount": "$10,000", "due": "At permitted assignment", "remarks": ""},
        {"type": "Relocation Fee", "amount": "$10,000+", "due": "At relocation", "remarks": "Approval in sole discretion"},
        {"type": "Remodeling", "amount": "$25,000-$150,000", "due": "When complete or periodic payments", "remarks": "Once every 5 years"},
        {"type": "Insurance Reimbursement", "amount": "$500 per occurrence", "due": "Immediately", "remarks": "If franchisee fails to obtain required insurance"},
        {"type": "Late Payment", "amount": "1.5% per month on overdue amount", "due": "Immediately", "remarks": "All payments"},
        {"type": "Insufficient Funds Fee", "amount": "$30 per occurrence", "due": "Immediately", "remarks": ""},
        {"type": "Store Tech Maintenance", "amount": "$75/mo (1st register), $25/mo (2nd register)", "due": "Monthly", "remarks": ""},
        {"type": "Network Connection", "amount": "$233/mo", "due": "Monthly", "remarks": ""},
        {"type": "Credit Card Processing (EMV)", "amount": "$16/mo", "due": "Monthly", "remarks": ""},
        {"type": "In-Store Wi-Fi", "amount": "$18/mo", "due": "Monthly", "remarks": "GNC IT equipment only"},
        {"type": "Cellular Plan", "amount": "$16/mo", "due": "Monthly", "remarks": "If iPad for outside events"},
        {"type": "Financial Services (GNFS)", "amount": "$220-$345/mo per store (tiered)", "due": "Monthly", "remarks": "Optional/required; includes inventory, payroll, HR"},
        {"type": "Franchise Renewal", "amount": "$12,500", "due": "On or before expiration", "remarks": "May be prorated for shorter lease"},
        {"type": "Audit", "amount": "Cost of audit if 3%+ understatement", "due": "Immediately", "remarks": ""},
        {"type": "Sublease Rent", "amount": "Varies", "due": "Monthly", "remarks": "Only if subleasing from franchisor"},
        {"type": "Non-compliance (notice failure)", "amount": "Up to $1,000", "due": "As incurred", "remarks": "Failure to give proper renewal notice"},
        {"type": "Indemnification", "amount": "Varies", "due": "As incurred", "remarks": ""},
        {"type": "Attorneys' Fees", "amount": "Varies", "due": "As incurred", "remarks": "If non-compliance with FA"},
        {"type": "Liquidated Damages", "amount": "Formula-based", "due": "Immediately", "remarks": "Avg monthly royalty × remaining months"},
        {"type": "Default Cure Fee", "amount": "Up to $1,000 per occurrence", "due": "Before cure expiration", "remarks": ""},
        {"type": "Annual Inventory Fee", "amount": "$540", "due": "Annually", "remarks": "Included in GNFS if enrolled"},
        {"type": "Non-compliance Management Fee", "amount": "25% of total gross sales", "due": "As incurred", "remarks": "If franchisor operates store due to non-compliance"},
        {"type": "Operating Management Fee", "amount": "$2,000/week", "due": "As incurred", "remarks": "Death/disability period"},
        {"type": "Securities Offering Fee", "amount": "$5,000", "due": "Upon submission", "remarks": "Per proposed offering"}
      ],
      "table_notes": [
        "Note 1: All fees generally non-refundable; may be reduced case-by-case.",
        "Note 2: Royalty 6% of gross sales.",
        "Note 3: Advertising fee currently 3%, may change on 30 days notice. Company stores not required to contribute.",
        "Note 8: GNFS tiered pricing: 1 store $345, 2-5 stores $320/store, 6-9 $295, 10-14 $245, 15+ $220.",
        "Note 11: Liquidated damages = max(avg monthly royalty for 2 years, avg monthly royalty for 12 months) × remaining months in term.",
        "Note 14: Non-compliance management fee of 25% applies when franchisor assumes operations due to default."
      ]
    },
