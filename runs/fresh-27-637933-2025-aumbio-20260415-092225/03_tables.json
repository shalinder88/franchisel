    {
      "table_id": "T07_item17_fa_provisions",
      "item": 17,
      "title": "Renewal, Termination, Transfer and Dispute Resolution — Franchise Agreement",
      "source_pages": [32, 33, 34, 35],
      "columns": ["provision", "fa_section", "summary"],
      "rows": [
        {"provision": "(a) Term", "fa_section": "2.1", "summary": "10 years from FA date unless terminated earlier"},
        {"provision": "(b) Renewal", "fa_section": "2.2", "summary": "Two additional 5-year terms if still franchising and in good standing; must sign then-current FA which may be materially different"},
        {"provision": "(c) Renewal requirements", "fa_section": "2.2(i)-(viii)", "summary": "Timely notice, sign new agreement, release, other documents, pay fee"},
        {"provision": "(d) Termination by you", "fa_section": "16.1", "summary": "60 days notice of franchisor default if uncured"},
        {"provision": "(e) Termination without cause", "fa_section": "N/A", "summary": "Not applicable"},
        {"provision": "(f) Termination with cause", "fa_section": "16.2; 16.3", "summary": "Each obligation is material; breach may result in termination"},
        {"provision": "(g) Cause - curable defaults", "fa_section": "16.2; 16.3", "summary": "Failure to pay (5-day cure), obtain covenants (5 days), procure insurance, lease default, failure to open within 120 days, other breaches"},
        {"provision": "(h) Cause - non-curable", "fa_section": "16.2", "summary": "Misrepresentation, false books, failure to submit reports/pay fees, 2+ failing inspections in 12 months, unauthorized products, abandonment, felony, trademark misuse, unapproved transfers, repeated defaults, fraud, bankruptcy/insolvency, selling sound-wave equipment wholesale/retail"},
        {"provision": "(i) Post-termination obligations", "fa_section": "Articles 17-18", "summary": "Pay amounts due, de-identify, return confidential info, cancel assumed names, cease advertising, comply with post-term covenants"},
        {"provision": "(j) Assignment by franchisor", "fa_section": "15.1", "summary": "No restriction; may assign without franchisee approval"},
        {"provision": "(k) Transfer definition", "fa_section": "15.2", "summary": "Sale, assignment, conveyance, pledge, mortgage, or other encumbrance of any interest"},
        {"provision": "(l) Franchisor approval of transfer", "fa_section": "15.4", "summary": "Required; not unreasonably withheld"},
        {"provision": "(m) Conditions for transfer approval", "fa_section": "15.4", "summary": "Transferee qualifies, amounts paid, not competitive, training completed, signs then-current FA, transfer fee paid, release signed, guaranty signed, non-compete agreed"},
        {"provision": "(n) ROFR", "fa_section": "None", "summary": "Not applicable"},
        {"provision": "(o) Option to purchase", "fa_section": "None", "summary": "Not applicable"},
        {"provision": "(p) Death/disability", "fa_section": "15.3", "summary": "Representative must transfer within 6 months; same conditions as any transfer"},
        {"provision": "(q) In-term noncompete", "fa_section": "18.5(i)", "summary": "No competing business anywhere in U.S."},
        {"provision": "(r) Post-term noncompete", "fa_section": "18.5(ii)", "summary": "2 years within territory or 50 miles of location at termination/expiration"},
        {"provision": "(s) Modification", "fa_section": "23.3", "summary": "Written and signed; but franchisor may change Operations Manual and System Standards"},
        {"provision": "(t) Integration", "fa_section": "Article 27", "summary": "Only FA terms binding (subject to state law); FDD representations not disclaimed"},
        {"provision": "(u) Dispute resolution", "fa_section": "Article 19", "summary": "Mediation and arbitration in city of HQ; JAMS rules; except for monies owed, injunctive relief, real estate"},
        {"provision": "(v) Choice of forum", "fa_section": "19.7", "summary": "Franchisor home county and state (subject to state law)"},
        {"provision": "(w) Choice of law", "fa_section": "Article 25", "summary": "Illinois law (except federal law; subject to state law)"}
      ],
      "table_notes": [],
      "provenance": "Item 17, PDF pages 32-35"
