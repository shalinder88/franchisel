      "item": 5,
      "title": "Initial Franchise Fee / Development Fee Schedule",
      "source_pages": [9, 10],
      "columns": ["units", "fee"],
      "rows": [
        {"units": "1 franchise", "fee": "$50,000"},
        {"units": "2 franchises (MUDA)", "fee": "$90,000"},
        {"units": "3 franchises (MUDA)", "fee": "$125,000"}
      ],
      "table_notes": [
        "Initial Franchise Fee is uniform and fully earned and nonrefundable on signing.",
        "Development Fee paid upon signing MUDA and first Franchise Agreement.",
        "Site Evaluation Fee: $1,000 per visit (3rd+ visits) plus out-of-pocket expenses."
      ],
      "provenance": "Item 5, PDF pages 9-10"
    },
    {
      "table_id": "T02_item6_other_fees",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [10, 11, 12],
      "columns": ["fee_type", "amount", "due_date", "remarks"],
      "rows": [
        {"fee_type": "Royalty Fee", "amount": "6% of Gross Revenues", "due_date": "Monthly, by 5th day", "remarks": "From first day open for business"},
        {"fee_type": "Brand Fund", "amount": "1% of Gross Revenue", "due_date": "Monthly, by 5th day", "remarks": "Currently collected at 1%"},
        {"fee_type": "Transfer Fee", "amount": "50% of then-current IFF", "due_date": "At time of transfer", "remarks": "For >50% interest transfer. No fee for one-time entity conversion."},
        {"fee_type": "Management Fee", "amount": "$500 per day", "due_date": "Within 10 days of invoice", "remarks": "If franchisor operates after death/disability. Subject to Inflation Adjustment."},
        {"fee_type": "Audit", "amount": "Cost of audit + 18% interest/annum on understatement", "due_date": "Upon completion", "remarks": "If reports not provided or understatement exceeds 2%"},
        {"fee_type": "Supplier Evaluation Fee", "amount": "$500", "due_date": "When invoiced", "remarks": "To evaluate alternate supplier"},
        {"fee_type": "Additional Training & Assistance", "amount": "$500/day/person + per diem", "due_date": "When invoiced", "remarks": "At franchisee request or if franchisor determines additional training needed"},
        {"fee_type": "Interest on Late Payments", "amount": "18% per annum or max allowed by law", "due_date": "When invoiced", "remarks": "From date of nonpayment on all overdue amounts"},
        {"fee_type": "Mandatory Convention Attendance", "amount": "$1,000 + employee salary/per diem/travel", "due_date": "If fail to attend", "remarks": "National and regional meetings required"},
        {"fee_type": "Fee for Lost Manuals", "amount": "$500", "due_date": "When invoiced", "remarks": "Per lost/misplaced manual"},
        {"fee_type": "Indemnification", "amount": "Actual attorneys' fees and costs", "due_date": "As incurred", "remarks": "For damages, claims, lawsuits related to franchise"},
        {"fee_type": "Technology Fee", "amount": "$100 per month", "due_date": "Monthly, by 5th day", "remarks": "Includes proprietary client management system, website. Subject to increase upon notice."},
        {"fee_type": "Local Marketing Requirement", "amount": "Minimum $1,500 per month", "due_date": "As incurred", "remarks": "Must market per franchisor standards"},
        {"fee_type": "Attorney's Fees", "amount": "Actual fees", "due_date": "As incurred", "remarks": "If noncompliant with FA obligations"},
        {"fee_type": "Liquidated Damages", "amount": "Royalty + Brand Fund for lesser of 2 years or remaining term", "due_date": "On demand", "remarks": "If terminated for default or franchisee terminates without right"},
        {"fee_type": "On-Site Inspection Fee", "amount": "Up to $5,000", "due_date": "Upon invoice", "remarks": "If reports missing or material deficiencies found"},
        {"fee_type": "Prohibited Product/Service Fine", "amount": "$500 per day", "due_date": "If incurred", "remarks": "In addition to other remedies"}
      ],
      "table_notes": [
        "Note 1: All fees imposed by franchisor, payable to franchisor, uniformly imposed. Collected by automatic bank drafts.",
        "Note 2: Gross Revenues = all revenue whether cash/credit, exchanges, barter, insurance proceeds for lost profit. Excludes separately stated sales taxes.",
        "Note 3: Renewal Fee compensates for legal/administrative costs including premises inspection.",
        "Note 4: Inflation Adjustment = increase based on CPI-U (1982-1984=100) or comparable index.",
        "Note 5: Transfer Fee compensates for attorney fees, training, other assistance for transferee.",
        "Note 6: Audit rights apply if under-reporting exceeds 2% or reports not provided; costs include travel/lodging/meals.",
        "Note 7: Technology Fee includes client management system license, website maintenance, upgrades.",
        "Note 8: Liquidated damages calculated as average monthly royalty for prior 12 months x 24 months."
      ],
      "provenance": "Item 6, PDF pages 10-13"
    },
