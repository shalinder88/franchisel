    {
      "table_id": "T01",
      "source_item": "Item 6",
      "source_pages": [21, 22, 23, 24],
      "title": "Fees Under the Franchise Agreement and Development Rights Agreement",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Royalty Fee", "amount": "5% of Gross Rooms Revenue", "due_date": "10th of each month (Payment Day)", "remarks": "May be reduced for years 1-3 of new construction"},
        {"fee": "Cooperative advertising", "amount": "As Cooperative determines", "due_date": "As Cooperative determines", "remarks": "Only if franchisee participates"},
        {"fee": "World of Hyatt assessment", "amount": "2% of eligible revenue (1% for on-property enrollment)", "due_date": "Monthly", "remarks": "Could increase if costs increase"},
        {"fee": "Comfort letter fee", "amount": "$2,500", "due_date": "As incurred", "remarks": "Per comfort letter"},
        {"fee": "Quality assurance/FIP/BPP", "amount": "FIP: $5,000-$20,000/stage; BPP: $45,000/year", "due_date": "As incurred", "remarks": "Non-compliance only; up to 100% reduction for improvement"},
        {"fee": "On-site QA inspections", "amount": "$1,500-$2,000/annual; $2,000 re-inspection", "due_date": "As incurred", "remarks": "Must reverse folio charge for inspection company"},
        {"fee": "Additional training", "amount": "$950/trainer/day + expenses", "due_date": "As incurred", "remarks": "If requested or required"},
        {"fee": "PMS subscription", "amount": "$3.90/room/month", "due_date": "Monthly", "remarks": "Vendor pass-through, subject to increase"},
        {"fee": "Training tools and materials", "amount": "$3.64/room/year", "due_date": "Annually", "remarks": ""},
        {"fee": "Owner convention", "amount": "$2,000-$5,000/attendee", "due_date": "As incurred", "remarks": "Annual or biennial plus travel"},
        {"fee": "Leadership summit", "amount": "$3,000-$6,000/attendee", "due_date": "As incurred", "remarks": "~Every 4 years plus travel"},
        {"fee": "Application fee for new rooms", "amount": "Greater of $5,000 or $500 × new rooms", "due_date": "As incurred", "remarks": "Only if adding rooms during term"},
        {"fee": "GM University", "amount": "$2,700/new GM", "due_date": "As incurred", "remarks": "New/promoted GMs plus travel"},
        {"fee": "Operator approval/re-entry", "amount": "$10,000-$20,000", "due_date": "Before screening", "remarks": "New management companies only"},
        {"fee": "Transfer fee", "amount": "Change of ownership application fee ($100,000)", "due_date": "With transfer application", "remarks": "Refundable $7,500 if disapproved"},
        {"fee": "Review of offering materials", "amount": "$5,000", "due_date": "When submitting", "remarks": "Only for ownership interest offerings"},
        {"fee": "PIP fee (conversion/successor)", "amount": "$5,000", "due_date": "With franchise application", "remarks": ""},
        {"fee": "Royalty fee upon termination", "amount": "$5,000/day + costs", "due_date": "As incurred", "remarks": "If fail to de-identify after termination"},
        {"fee": "Liquidated damages", "amount": "See Note 6", "due_date": "15 days after termination", "remarks": "Greater of $4,000/room or up to 36 months × 8% revenue; 150% for Consequential Termination"},
        {"fee": "Audit expenses", "amount": "Cost of audit", "due_date": "As incurred", "remarks": "Only if 3%+ understatement or willful underpayment"},
        {"fee": "Late fee and interest", "amount": "$225 + 1.5%/month", "due_date": "As incurred", "remarks": "On amounts 7+ days late"},
        {"fee": "Indemnification", "amount": "Varies", "due_date": "As incurred", "remarks": ""},
        {"fee": "Testing new product/supplier", "amount": "$20,000", "due_date": "As incurred", "remarks": "If requesting approval"},
        {"fee": "Designer approval fees", "amount": "$2,000-$10,000", "due_date": "As incurred", "remarks": "Renovation design firm approval"},
        {"fee": "Insurance", "amount": "Premiums + $200/room/year", "due_date": "As incurred", "remarks": "Only if franchisee fails to maintain"},
        {"fee": "DRA application fees", "amount": "$50,000 + $500/room over 125", "due_date": "With franchise applications", "remarks": "For each Brand Hotel under DRA"}
      ],
      "table_notes": "Except for transfer fee, all fees non-refundable. We might negotiate some fees for strategic market development."
    },
