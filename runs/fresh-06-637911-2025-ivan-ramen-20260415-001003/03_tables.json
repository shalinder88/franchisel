    {
      "table_id": "T01_item6_other_fees",
      "source_item": 6,
      "source_pages": [10, 11, 12, 13, 14],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Continuing Royalty", "amount": "5% of Gross Revenues", "due": "Monthly, 15th of next month", "remarks": "Fixed during FA term. Gross Revenues defined in FA Section 5.05."},
        {"fee": "System Brand Contribution", "amount": "Up to 1.5% of Gross Revenues", "due": "Same as royalty", "remarks": "Fund not yet formed. Will not exceed 1.5% during term."},
        {"fee": "System Technology Fee", "amount": "Up to 1.0% of Gross Revenues (currently 0%)", "due": "Same as royalty", "remarks": "Reserved right; currently not charged."},
        {"fee": "Proprietary Products", "amount": "$7,333/month estimated", "due": "On order", "remarks": "Noodles $2,750/mo; dashi/specialty $1,250/mo; soup concentrates $3,333/mo."},
        {"fee": "Proprietary Software Costs", "amount": "Currently none", "due": "TBD", "remarks": "No charge for initial license; may charge for updates."},
        {"fee": "Testing Fee", "amount": "$1,000-$1,500", "due": "On request", "remarks": "For testing proposed alternative supplier products/services."},
        {"fee": "Initial Training", "amount": "Included for up to 6 people; additional: $2,500/person", "due": "Before training; expenses as incurred", "remarks": "Training at NYC location; franchisee pays all travel/lodging."},
        {"fee": "On-Site Training and Assistance", "amount": "$2,500/day", "due": "On request", "remarks": "Optional; not required to be provided."},
        {"fee": "Insurance Reimbursement", "amount": "$55,000-$65,000/year (if franchisor pays)", "due": "As carrier requires", "remarks": "Franchisee pays insurer directly; franchisor may pay if franchisee fails."},
        {"fee": "Relocation Analysis", "amount": "Up to $5,000", "due": "On request", "remarks": "Franchisor's reasonable costs of considering relocation request."},
        {"fee": "Taxes", "amount": "Varies", "due": "Promptly when due", "remarks": "All taxes except franchisor's corporate income taxes."},
        {"fee": "Advances", "amount": "Varies", "due": "On request", "remarks": "Amounts advanced to third parties on franchisee's behalf."},
        {"fee": "Late Charge", "amount": "3% of overdue amount; $50/month for late financials", "due": "On request", "remarks": "CA max 10% annually. Formula fixed during FA term."},
        {"fee": "Audit Expenses", "amount": "Varies", "due": "Per Note 4", "remarks": "Franchisee pays if Gross Revenue understatement ≥2%."},
        {"fee": "Successor Term Fee", "amount": "$35,000", "due": "Before signing successor FA", "remarks": "See Item 17."},
        {"fee": "Transfer Fee (FA)", "amount": "$10,000", "due": "Before approval", "remarks": "See Item 17."},
        {"fee": "Transfer Fee (ADA)", "amount": "$10,000", "due": "Before approval", "remarks": "See Item 17."},
        {"fee": "Transfer Related Costs", "amount": "Varies", "due": "When incurred", "remarks": "Investigation costs, landlord consent, etc."},
        {"fee": "Securities Offering Review", "amount": "$10,000+", "due": "When incurred", "remarks": "Review of franchisee's proposed securities offering."},
        {"fee": "Management Fee (Death/Disability)", "amount": "Greater of 2x salary or 10% of weekly Gross Revenue", "due": "See remarks", "remarks": "If franchisor operates business on behalf of estate; in addition to royalties."},
        {"fee": "Indemnification", "amount": "Varies", "due": "When incurred", "remarks": "FA Section 8.10."},
        {"fee": "Application of Funds", "amount": "Varies", "due": "When received", "remarks": "Franchisor can apply payments to oldest obligation."},
        {"fee": "Attorneys'/Experts' Fees", "amount": "Varies", "due": "Promptly when due", "remarks": "Broad recovery in enforcement actions."}
      ],
      "table_notes": [
        "All fees are nonrefundable and uniformly imposed unless otherwise stated.",
        "Note 1: If Alcohol Restriction Law applies, increased non-alcohol percentages required to equalize fees.",
        "Note 2: Proprietary software license included in IFF; franchisee pays for updates.",
        "Note 3: Insurance premiums vary by location, creditworthiness, risk profile.",
        "Note 4: If understatement ≥2%, franchisee pays audit + amounts due + interest. If ≥8%, franchisor can terminate.",
        "Note 5: Broad attorneys' fees recovery in enforcement, third-party litigation, and default termination."
      ]
    },
