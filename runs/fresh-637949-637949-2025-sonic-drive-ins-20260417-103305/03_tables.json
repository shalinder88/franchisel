    {
      "id": "T_item5_initial_fees",
      "item": "5",
      "title": "Initial Fees Summary",
      "source_pages": [28],
      "columns": ["Fee Type", "Amount", "Notes"],
      "rows": [
        ["Standard initial franchise fee (Traditional/Non-Drive-In)", "$15,000", "Nonrefundable"],
        ["Non-Traditional Location", "$11,250", "$1,125 × years in term, up to 10"],
        ["Reopened closed restaurant (existing franchisee)", "$5,000", ""],
        ["Reopened closed restaurant (new franchisee)", "$12,500", ""],
        ["Development fee", "$10,000 per restaurant", "$10,000 credited toward each FA fee"],
        ["Site Design Fee (PSL)", "$1,200", "Optional"],
        ["Kitchen Layout Design Fee (PKL - new)", "$1,200", "Optional"],
        ["Kitchen Layout Design Fee (PKL - remodel)", "$750", "Optional"],
        ["Training fee (GM Leadership Class)", "$200 per attendee", "Nonrefundable"]
      ],
      "table_notes": ["All fees nonrefundable. During FY2024, fees ranged from $0 to $45,000."]
    },
    {
      "id": "T_item6_other_fees",
      "item": "6",
      "title": "Other Fees Table",
      "source_pages": [29, 30, 31],
      "columns": ["Fee Type", "Amount", "Due Date", "Remarks"],
      "rows": [
        ["Royalty fee", "5% of Gross Sales", "Monthly 10th of next month", "Reduced via NRO and other incentives"],
        ["Brand fee/SBF contribution", "0.90% of Gross Sales", "Monthly 10th of next month", "Payable to Sonic Brand Fund"],
        ["Advertising cooperative/SMF contribution", "1.625%–3.25% (minimum) of Gross Sales", "Monthly 10th of next month", "Market-type dependent: Core 0.5% coop + 2.75%–4.5% SMF; Developing 0.5% coop + 4.5% SMF; New 5% SMF"],
        ["Technology fee/BTF contribution", "0.25% of Gross Sales", "Monthly 10th of next month", "Subject to 67% franchisee vote to continue post-3/2026"],
        ["Additional training fee", "$200/person; $1,000/failed inspection", "Before training", "New GM must attend within 6 months"],
        ["Site design/kitchen layout fee", "$1,200 PSL / $750 PKL", "Upon request", "Remodeling only"],
        ["Transfer fee", "$1,000 (non-control/family/wholly-owned); $3,000 (other)", "Before transfer", ""],
        ["Audit fee, interest, surcharge", "Unpaid amounts + interest + 10% surcharge", "When billed", "If ≥3% understatement"],
        ["Late charge", "1.75% per month", "Monthly", ""],
        ["Renewal fee", "$15,000", "Upon signing new FA", ""],
        ["Insurance", "Cost of obtaining", "As incurred", "If franchisee fails to maintain"],
        ["Management fee", "3% of Gross Sales", "Monthly 10th of next month", "Only if franchisor manages pending option to purchase"],
        ["Indemnification", "Varies", "On demand", ""],
        ["Enforcement costs", "Varies", "On demand", "Prevailing party recovers"]
      ],
      "table_notes": [
        "(1) All fees payable to franchisor, nonrefundable, and uniform unless otherwise noted.",
        "(2) Standard royalty 5%. NRO incentive: 1% (Yr 1), 1.5% (Yr 2), 2% (Yr 3), 2.5% (Yr 4), 5% (Yr 5+). Relocation: 1%/2%/3%/5%. Early Opening: 0% until required opening date.",
        "(3) Gross Sales definition excludes refunds, exchanges, taxes, discounts/coupons, stored-value card sales, and proceeds from restaurant sale.",
        "(4) SMF allocation: Core markets 0.5% coop + 2.75%–4.5% SMF; Developing 0.5% coop + 4.5% SMF; New markets 5% all to SMF. Max total 5% but cooperative can vote for additional.",
        "(5) BTF: For Drive-Ins open full CY2020, flat monthly amount through 3/2026. Requires 67% franchisee vote to continue.",
        "(6) Multi-Brand Location must also pay all fees under Other Franchisor's agreements."
      ]
    },
