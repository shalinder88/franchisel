      "table_id": "T5_initial_fees",
      "item": 5,
      "title": "Initial Fees",
      "source_pages": [12, 13],
      "columns": ["Fee", "Amount", "Notes"],
      "rows": [
        {"Fee": "Initial Franchise Fee", "Amount": "$45,000", "Notes": "Lump sum, nonrefundable. Application Fee of $2,500 credited toward this."},
        {"Fee": "Application Fee", "Amount": "$2,500", "Notes": "Nonrefundable"},
        {"Fee": "Training Fee (Resource Evaluation & Guidance)", "Amount": "$10,000", "Notes": "Nonrefundable, due 14 days prior to training"},
        {"Fee": "Computer Hardware/Software (PMS, CRS, CRM)", "Amount": "$6,000 - $22,000", "Notes": "Nonrefundable, may not be required if existing systems are compatible"}
      ],
      "table_notes": [
        "All fees are nonrefundable.",
        "Application approval within 30 days. Must sign franchise agreement within 120 days of approval.",
        "Training fee subject to change at franchisor's sole discretion."
      ]
    },
    {
      "table_id": "T6_other_fees",
      "item": 6,
      "title": "Other Fees",
      "source_pages": [14, 15, 16, 17, 18, 19, 20, 21, 22],
      "columns": ["Name of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"Name of Fee": "Royalty", "Amount": "0% (30 days) → 2.5% (days 31-90) → 4% (days 91-180) → 5% (thereafter)", "Due Date": "Monthly, 30 days after billing", "Remarks": "Based on Gross Room Revenue. Never decreases once a rate tier is achieved."},
        {"Name of Fee": "Marketing and Reservation Fund Fee", "Amount": "2.50% of GRR", "Due Date": "Monthly, 30 days after billing", "Remarks": "Nonrefundable"},
        {"Name of Fee": "Revenue Intelligence Service", "Amount": "1% of GRR", "Due Date": "Monthly, 30 days after billing", "Remarks": "Funds revenue management and business intelligence. Rate may change on 120 days' notice."},
        {"Name of Fee": "Guest Loyalty Program", "Amount": "1% of GRR", "Due Date": "Monthly, 30 days after billing", "Remarks": "Rate may change on 120 days' notice."},
        {"Name of Fee": "Initial Training", "Amount": "$10,000 + travel/lodging/meals", "Due Date": "14 days before training", "Remarks": "Nonrefundable. Includes Resource Evaluation and Guidance Program."},
        {"Name of Fee": "Retraining", "Amount": "$4,125 (subject to change)", "Due Date": "14 days before start", "Remarks": "Additional training if required or requested."},
        {"Name of Fee": "Administrative Training", "Amount": "Travel, lodging, meal, employee expenses", "Due Date": "N/A", "Remarks": "Optional training at My Place University, Aberdeen, SD."},
        {"Name of Fee": "Travel Agent/Internet/GDS Fees", "Amount": "Reimbursement of all fees", "Due Date": "30 days after billing", "Remarks": "Franchisor may pay on your behalf. No commissions paid."},
        {"Name of Fee": "Transfer", "Amount": "50% of then-current Initial Franchise Fee", "Due Date": "Before transfer approval", "Remarks": "No fee if transfer to entity with 51%+ ownership."},
        {"Name of Fee": "Audit", "Amount": "Cost of audit + underpayment + interest", "Due Date": "10 days after notification", "Remarks": "Payable if audit shows 2%+ underpayment."},
        {"Name of Fee": "Renewal Fee", "Amount": "Then-current Application Fee + Initial Franchise Fee", "Due Date": "180 days before expiration", "Remarks": "5-year extension if in Good Standing."},
        {"Name of Fee": "Indemnification", "Amount": "As incurred", "Due Date": "As incurred", "Remarks": "Must indemnify franchisor against claims."},
        {"Name of Fee": "Damages", "Amount": "Unspecified", "Due Date": "30 days after termination", "Remarks": "All damages caused by default."},
        {"Name of Fee": "Liquidated Damages", "Amount": "As incurred", "Due Date": "As incurred", "Remarks": "$1,000/day pre-approval operation. Premature termination: 36× avg monthly fees (see footnote 12)."},
        {"Name of Fee": "Interest", "Amount": "Highest rate allowed by law", "Due Date": "Immediately upon billing", "Remarks": "On delinquent sums."},
        {"Name of Fee": "Late Fees", "Amount": "$200 per occurrence", "Due Date": "With delinquent payment", "Remarks": "Per late payment and per late report."},
        {"Name of Fee": "Dishonored Check Fees", "Amount": "Max allowed by SD law ($60)", "Due Date": "When made good", "Remarks": "Per dishonored check."},
        {"Name of Fee": "Approved Supplier", "Amount": "Not to exceed $1,000", "Due Date": "30 days after billing", "Remarks": "For supplier approval review."},
        {"Name of Fee": "Securities Offering Fee", "Amount": "50% of then-current Initial Franchise Fee", "Due Date": "With offering application", "Remarks": "If franchisee makes public equity offering."},
        {"Name of Fee": "Reinspection Fee", "Amount": "$2,500", "Due Date": "30 days after billing", "Remarks": "After unsatisfactory inspection/QA evaluation."},
        {"Name of Fee": "Convention", "Amount": "Registration + travel/lodging/meals", "Due Date": "Pre-registration required", "Remarks": "Mandatory attendance for franchisee and GM."},
        {"Name of Fee": "Technology Subscription Fee", "Amount": "$1,204/month + sales tax", "Due Date": "Monthly, 30 days after billing", "Remarks": "PMS, CRS, CRM, website, email, AV/patch, firewall. Variable by rooms/computers."},
        {"Name of Fee": "Website Fee", "Amount": "$1,000 annually", "Due Date": "30 days after billing, then annually", "Remarks": "Franchisor controls content."},
        {"Name of Fee": "Change of Opening Date", "Amount": "$5,000", "Due Date": "30 days after billing", "Remarks": "For schedule changes up to 90 days, plus reimbursement of costs."}
      ],
      "table_notes": [
        "All fees payable to franchisor are nonrefundable and uniformly imposed unless noted otherwise.",
        "Footnote 12 details liquidated damages formula for premature termination: 36-month projection or remaining term multiplied by average monthly fees.",
        "Revenue Intelligence Service and Guest Loyalty Program rates may change with 120 days' notice."
      ]
    },
