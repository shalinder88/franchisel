        {"type": "Insurance", "amount_low": 10000, "amount_high": 40000, "method": "As incurred", "when": "Before opening", "to_whom": "Insurance carriers"},
        {"type": "Professional Fees", "amount_low": 2000, "amount_high": 10000, "method": "As incurred", "when": "Before opening", "to_whom": "Attorneys and accountants"},
        {"type": "Additional Funds - 3 Months", "amount_low": 150000, "amount_high": 300000, "method": "As incurred", "when": "Before opening", "to_whom": "Suppliers, consultants, banks, etc."}
      ],
      "totals": {"low": 175000, "high": 400000},
      "table_notes": [
        "1. Conversion model — excludes real estate, rent, security deposits, occupancy costs, and existing hotel operating costs.",
        "2. Signage costs vary by location, type, quantity, size, specifications, condition, labor costs.",
        "3. Insurance costs depend on policy limits, assets, revenue, employees, location. May not incur additional if existing coverage sufficient.",
        "4. Professional fees for attorney/accountant; does not include business consultants.",
        "5. First 3 months operating expenses: wages, utilities, payroll taxes, supplies, maintenance, working capital.",
        "6. Estimates based on 60 Guest Room hotel. Neither franchisor nor affiliates offer financing."
      ]
