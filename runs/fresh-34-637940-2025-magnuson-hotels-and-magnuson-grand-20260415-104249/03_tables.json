{
  "tables": [
    {
      "table_id": "item6_other_fees",
      "source_item": 6,
      "source_pages": [11, 12, 13, 14],
      "title": "Other Fees",
      "columns": ["Type of Fee", "Amount", "Due Date", "Remarks"],
      "rows": [
        {"fee": "Continuing Fee", "amount": "8% of Gross Room Revenue", "due": "Monthly by invoice due date", "remarks": "See Note 2"},
        {"fee": "GDS Booking Fees", "amount": "$11.50 per GDS booking (subject to change)", "due": "Monthly by invoice due date", "remarks": "Per booking through GDS channels"},
        {"fee": "Third-Party Distribution Channel Fees", "amount": "10% (GDS), 15-20% (other channels) (subject to change)", "due": "Payable to Third-Party Distribution Channel or reimbursed to franchisor", "remarks": "Reimbursement of all fees, expenses, commissions"},
        {"fee": "Airbnb Connection Fees", "amount": "$100-$260 per month (subject to change)", "due": "Monthly by invoice due date", "remarks": "Monthly fee for Airbnb platform connection"},
        {"fee": "Minimum Invoice Revenue", "amount": "$250 per month (subject to change)", "due": "As invoiced", "remarks": "Deficiency payment if aggregate fees fall below minimum; up to 10%/year increase"},
        {"fee": "Approved PMS Connection Fee", "amount": "$300-$2,000 per year", "due": "As incurred", "remarks": "If using Approved PMS instead of Magnuson Cloud PMS"},
        {"fee": "Insufficient Funds Fee", "amount": "$25 per occurrence", "due": "As invoiced", "remarks": "For returned/declined payments"},
        {"fee": "Late Payment Fee", "amount": "5% per occurrence + 1.5%/month", "due": "As incurred", "remarks": "On overdue amounts; max rate per law"},
        {"fee": "Conversion Violation", "amount": "$1,000 per month", "due": "Monthly by invoice due date", "remarks": "Failure to convert by deadline"},
        {"fee": "Standards Violation", "amount": "$2,000 per month", "due": "Monthly by invoice due date", "remarks": "Non-compliance with Brand Standards"},
        {"fee": "Re-booking Fee / Guest Relations", "amount": "200% of booking fee or alternate accommodation cost (whichever higher)", "due": "As incurred", "remarks": "Failure to honor confirmed reservation; includes guest complaint reimbursement"},
        {"fee": "Failed Inspection Fee", "amount": "$2,500 (subject to change) + follow-up costs", "due": "As incurred", "remarks": "Violations of Brand Standards found on inspection"},
        {"fee": "Insurance Certificate Fee", "amount": "$250 per month", "due": "As incurred", "remarks": "Failure to provide insurance certificates"},
        {"fee": "Audit Costs", "amount": "Reimbursement of all audit costs", "due": "As incurred", "remarks": "If understatement of Gross Room Revenue"},
        {"fee": "Enforcement Costs and Attorneys' Fees", "amount": "Varies", "due": "As incurred", "remarks": "Prevailing party entitled to costs"},
        {"fee": "Re-Activation Fee", "amount": "$750 per occurrence + $25/day offline (subject to change)", "due": "As invoiced", "remarks": "Re-activation after service suspension; up to 10%/year increase"},
        {"fee": "Extended Closure Fee", "amount": "$750 per occurrence + $25/day offline (subject to change)", "due": "As incurred", "remarks": "Guest Room out of inventory >14 days without authorization; up to 10%/year increase"},
        {"fee": "Indemnification", "amount": "Varies", "due": "As incurred", "remarks": "Claims/damages from hotel operation"},
        {"fee": "Termination Damages", "amount": "Varies", "due": "Within 10 days of termination", "remarks": "Continuing fees from termination to earlier of (i) term expiration or (ii) 1 year"},
        {"fee": "Inconvenience Fee", "amount": "$2,000 (subject to change, up to $5,000)", "due": "As incurred", "remarks": "Closure/termination with <90 days notice"},
        {"fee": "De-Identification Processing Fee", "amount": "$9,995 (subject to change)", "due": "As incurred", "remarks": "If de-identification not completed within 30 days"}
      ],
      "table_notes": [
        "1. All fees imposed and collected by and payable to franchisor except as noted. Nonrefundable unless otherwise noted. Franchisor may negotiate fees.",
        "2. Must report all Gross Room Revenue on PMS including walk-in/cash. If misreported, fees calculated at 110% of 3-month average."
      ]
    },
