    {
      "table_id": "item6_other_fees",
      "item": "Item 6",
      "title": "Other Fees",
      "source_pages": [17, 18, 19],
      "columns": ["Type of Fee", "Amount", "Date Due", "Remarks"],
      "rows": [
        {
          "fee_type": "Royalty",
          "amount": "60% on first $5,000 revenue (50% early-pay); 40% on revenue above $5,000 (30% early-pay); 20% Incentive Rate on incremental above 2-yr average (early-pay only); 15% on business services (10% early-pay); 20% Product Specific on POM and Second Look",
          "date_due": "Within 30 days after end of Reporting Period (reduced if within 4 days)",
          "remarks": "Revenue = all revenue from all products/services. Reporting Periods: semi-monthly Feb-Mar, monthly May-Jan, special April periods. Early-pay discount requires no overdue amounts."
        },
        {
          "fee_type": "POM Extended Service Plan and POM Protection Program",
          "amount": "20% Product Specific Royalty on POM + designated premium (not exceeding $15 last Tax Season) + $50 deductible per approved claim",
          "date_due": "As incurred and paid as directed",
          "remarks": "Required service. Premium determined annually by actuarial evaluation."
        },
        {
          "fee_type": "Transfer",
          "amount": "$2,500",
          "date_due": "Prior to approval of Transfer",
          "remarks": "May be waived by H&R Block at sole discretion."
        },
        {
          "fee_type": "Audit",
          "amount": "Cost of inspection or audit",
          "date_due": "As incurred",
          "remarks": "Only if audit shows ≥2% understatement of revenue."
        },
        {
          "fee_type": "Additional Training",
          "amount": "$35 annual fee per participant",
          "date_due": "As incurred",
          "remarks": "Additional tax preparation training. Required annual training ~19 hours provided free, but franchisee pays labor."
        },
        {
          "fee_type": "Term Loan Interest Rate Default",
          "amount": "4% increase to loan interest rate",
          "date_due": "As incurred",
          "remarks": "Only if franchisee defaults under Term Loan or Short-Term Loan security agreement."
        }
      ],
      "table_notes": [
        "Products and services subject to Product Specific Royalty Rate may change; current rates set in Manual.",
        "All fees uniformly imposed and nonrefundable.",
        "Franchisee must sign documents authorizing automatic debit of business checking account for royalty payments."
      ]
    },
