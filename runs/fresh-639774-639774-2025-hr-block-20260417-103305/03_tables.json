      "table_id": "item17_franchise_relationship",
      "item": "Item 17",
      "title": "The Franchise Relationship",
      "source_pages": [41, 42, 43],
      "columns": ["Provision", "Section in FLA", "Summary"],
      "rows": [
        {"provision": "Term", "section": "4.1", "summary": "Ends June 1 following 10th full Tax Season after Effective Date"},
        {"provision": "Renewal/extension", "section": "4.2", "summary": "No automatic renewal; franchisor may offer successor at sole discretion"},
        {"provision": "Requirements to renew", "section": "4.2", "summary": "Sign new FLA if offered; terms may be materially different"},
        {"provision": "Termination by franchisee", "section": "15", "summary": "30 days notice before June 1 + payment of 25% of 3-year avg gross sales (or 100% of prior year if <3 years)"},
        {"provision": "Termination by franchisor without cause", "section": "None", "summary": "Not permitted"},
        {"provision": "Termination by franchisor with cause", "section": "13, 14", "summary": "Only if franchisee in default"},
        {"provision": "Curable defaults", "section": "14", "summary": "15+ days to cure"},
        {"provision": "Incurable defaults", "section": "13", "summary": "Prohibited competition/disclosure, 3+ defaults in 12 months, conviction, fraud, e-file prohibition, bankruptcy, false books, prohibited assignments, cross-default"},
        {"provision": "Post-termination obligations", "section": "16", "summary": "De-identification, payment, return files, assign phone/leases, 2-year real property restriction"},
        {"provision": "Franchisor assignment", "section": "18.4", "summary": "No restriction"},
        {"provision": "Transfer by franchisee", "section": "18", "summary": "Approval required; conditions include payment, no default, $2,500 fee, transferee qualifications"},
        {"provision": "ROFR", "section": "17", "summary": "30 days to match offer terms"},
        {"provision": "Death/disability", "section": "20", "summary": "Transfer within 6 months"},
        {"provision": "Noncompete during term", "section": "12", "summary": "45 miles from territory or any Network Office"},
        {"provision": "Noncompete post-term", "section": "12", "summary": "2 years, 25 miles from territory + non-solicitation (exception under §15)"},
        {"provision": "Modification", "section": "27", "summary": "Writing signed by both parties"},
        {"provision": "Integration", "section": "27", "summary": "Only FLA terms binding (subject to state law)"},
        {"provision": "Arbitration/mediation", "section": "None", "summary": "None"},
        {"provision": "Choice of forum", "section": "29", "summary": "State or federal court, Jackson County, Missouri"},
        {"provision": "Choice of law", "section": "29", "summary": "Missouri law"}
